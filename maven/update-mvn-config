help(){
    if [ ! -z "$1" ]; then
        local indent=10
        local formatl=" - %-"$indent"s: %s\n"
        local formatr=" - %"$indent"s: %s\n"
        echo
        echo "================================================================================"
        printf "$formatl" "filename" "$(basename $0)"
        printf "$formatl" "line" "$2"
        printf "$formatl" "callstack"
        local idx=1
        for func in ${FUNCNAME[@]:1}
        do
            printf "$formatr" "["$idx"]" $func
            ((idx++))
        done
        printf "$formatl" "cause" "$1"
        echo "================================================================================"
    fi
    echo
    echo "Usage: $(basename $0) [OPTIONS]"
    echo "  -h, --help       도움말 출력"
    echo "  /opt 디렉토리 하위의 apache-maven-* 버전 목록을 제공하고 환경 변수를 갱신합니다."
}

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    help
    exit 0
fi

##
# 지정된 기본 경로에서 Maven 설치 목록(디렉토리만)을 검색하여 출력하고 사용자의 선택을 받습니다.
#
# @param $1 {String} Maven 기본 설치 경로
#
# @return 선택된 Maven의 절대 경로를 출력
##
select_maven() {
    local base_dir="$1"
    local dirs=()

    # [수정됨] 와일드카드 검색 결과 중 '디렉토리'인 것만 배열에 추가 (tar.gz 등 제외)
    for item in "${base_dir}"/apache-maven-*; do
        if [ -d "$item" ]; then
            dirs+=("$item")
        fi
    done

    if [ ${#dirs[@]} -eq 0 ]; then
        echo ""
        return 1
    fi

    echo "대체 항목 maven에 대해 선택할 수 있는 버전이 있습니다." >&2
    echo "  선택       경로" >&2
    echo "------------------------------------------------------------" >&2
    for i in "${!dirs[@]}"; do
        echo "  $i          ${dirs[$i]}" >&2
    done
    echo "" >&2

    local sel_idx
    read -p "선택 번호를 입력하시오: " sel_idx >&2

    if ! [[ "$sel_idx" =~ ^[0-9]+$ ]] || [ "$sel_idx" -lt 0 ] || [ "$sel_idx" -ge "${#dirs[@]}" ]; then
        echo "잘못된 선택입니다." >&2
        return 1
    fi

    echo "${dirs[$sel_idx]}"
}

##
# 선택된 Maven 경로를 바탕으로 시스템 환경 변수를 갱신하는 설정 파일을 생성합니다.
#
# @param $1 {String} 선택된 Maven의 절대 경로
#
# @return 설정 파일 생성 완료 메시지 출력
##
generate_env_file() {
    local selected_mvn="$1"
    local env_file="$HOME/.maven_env"

    cat <<EOF > "$env_file"
# Auto-generated by update-mvn-config
export M2_HOME="$selected_mvn"
export MAVEN_HOME="$selected_mvn"

# 기존 PATH에 하드코딩된 구버전 Maven 경로를 깔끔하게 제거한 후 최상단에 새 경로 추가
if [[ ":\$PATH:" == *":/opt/apache-maven-"* ]]; then
    export PATH=\$(echo "\$PATH" | tr ':' '\n' | grep -v '^/opt/apache-maven-' | paste -sd ':' -)
fi

export PATH="\$MAVEN_HOME/bin:\$PATH"
EOF
    echo "[System] Maven 설정이 갱신되었습니다: $selected_mvn" >&2
}

# =======================================
# Main Logic
# =======================================
MAVEN_BASE="/opt"
SELECTED=$(select_maven "$MAVEN_BASE")

if [ -z "$SELECTED" ]; then
    help "Maven 디렉토리를 찾을 수 없거나 잘못된 번호를 선택했습니다." "$LINENO"
    exit 1
fi

generate_env_file "$SELECTED"

exit 0



