##
# sshctl 엔트리포인트 함수로, 전역 옵션과 서브커맨드를 파싱하고 각 명령을 디스패치한다.
# Entry point for sshctl; parses global options and subcommands, then dispatches to handlers.
#
# @param $1..$n {string} CLI 인자 (예: --config, -l, -a, -m 등) / CLI arguments (e.g. --config, -l, -a, -m)
#
# @return {int} 각 cmd_* 함수가 반환하는 코드 또는 die() 호출 시 exit 1
#         Exit code from the corresponding cmd_* function or 1 via die().
##
main() {
  ensure_dependencies

  # 기본값
  SHOW_CREDENTIAL="false"
  EXEC_CMD="connect"

  CONNECT_NUMBER=""

  local arg_config=""
  local arg_masterkey=""
  local show_help="false"
  local -a positional_args=()

  # 0) 전역 옵션 파싱
  #    - --config <path>
  #    - -s / --show-credential
  #    - -h / --help
  #    → 인자 전체를 훑으면서 처리하고, 나머지는 positional_args 에만 모은다.
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config)
        shift || true
        if [[ $# -eq 0 ]]; then
          echo "[ERROR] --config 옵션에는 설정 파일 경로가 필요합니다." >&2
          exit 1
        fi
        arg_config="$1"
        shift
        ;;
      --masterkey)
        shift || true
        if [[ $# -eq 0 ]]; then
          echo "[ERROR] --masterkey 옵션에는 masterkey(OpenSSH private key) 파일 경로가 필요합니다." >&2
          exit 1
        fi
        arg_masterkey="$1"
        shift
        ;;
      -s|--show-credential)
        SHOW_CREDENTIAL="true"
        shift
        ;;
      -n|--number)
        shift || true
        if [[ $# -eq 0 ]]; then
          echo "[ERROR] --number|-n 옵션에는 숫자 값이 필요합니다." >&2
          exit 1
        fi
        if ! [[ "$1" =~ ^[0-9]+$ ]]; then
          echo "[ERROR] --number|-n 값은 숫자여야 합니다: $1" >&2
          exit 1
        fi
        if [[ -n "${CONNECT_NUMBER:-}" ]]; then
          echo "[ERROR] --number|-n 옵션은 1회만 사용할 수 있습니다." >&2
          exit 1
        fi
        CONNECT_NUMBER="$1"
        shift
        ;;
      -h|--help)
        show_help="true"
        shift
        ;;
      --)
        shift
        # '--' 이후는 모두 순수 인자로 전달
        while [[ $# -gt 0 ]]; do
          positional_args+=("$1")
          shift
        done
        break
        ;;
      *)
        # 전역 옵션이 아닌 모든 인자는 그대로 positional 영역에 쌓는다.
        positional_args+=("$1")
        shift
        ;;
    esac
  done

  # 전역 옵션을 제거한 나머지 인자를 복원
  if [[ ${#positional_args[@]} -gt 0 ]]; then
    set -- "${positional_args[@]}"
  else
    set --
  fi

  # -h / --help 가 한 번이라도 등장했으면, 나머지 인자와 무관하게 도움말 출력
  if [[ "$show_help" == "true" ]]; then
    help ""
    return 0
  fi

  # CONFIG_FILE 우선순위
  #  1) --config
  #  2) SSH_CMD_CONFIG 환경변수
  #  3) DEFAULT_CONFIG_FILE
  if [[ -n "$arg_config" ]]; then
    CONFIG_FILE="$arg_config"
  elif [[ -n "${SSH_CMD_CONFIG:-}" ]]; then
    CONFIG_FILE="${SSH_CMD_CONFIG}"
  fi

  # MASTERKEY_FILE 우선순위
  #  1) --masterkey
  #  2) SSH_CMD_MASTERKEY
  #  3) SSM_CMD_MASTERKEY (오타/호환용 별칭)
  #  4) MASTERKEY_DEFAULT
  if [[ -n "$arg_masterkey" ]]; then
    MASTERKEY_FILE="$arg_masterkey"
  elif [[ -n "${SSH_CMD_MASTERKEY:-}" ]]; then
    MASTERKEY_FILE="${SSH_CMD_MASTERKEY}"
  elif [[ -n "${SSM_CMD_MASTERKEY:-}" ]]; then
    MASTERKEY_FILE="${SSM_CMD_MASTERKEY}"
  fi

  # 설정 파일 검증
  ensure_config_file
  # open ssh key md5 검증
  ensure_masterkey_md5

  # 남은 인자가 없으면: sshctl [Enter] → connect (masking list)
  if [[ $# -eq 0 ]]; then
    EXEC_CMD="connect"
    cmd_connect ""
    return 0
  fi

  # ------------------------------------------------------------
  # 1) 모드 옵션은 어느 위치든 허용한다.
  #    (ex: sshctl -m <expr>, sshctl <expr> -m 모두 동일하게 처리)
  #
  #  - 전역 옵션(--config/--masterkey/-s/-n/-h)은 이미 제거된 상태
  #  - 여기서는 "남은 인자"에서:
  #     * 모드 옵션(상호배타 1개) 탐지
  #     * 나머지 non-option 토큰은 <expr>로 취급(여러 토큰이면 공백으로 결합)
  # ------------------------------------------------------------
  local mode="connect"
  local mode_token=""
  local mode_count=0
  local -a expr_tokens=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --list|-l|--list-all)
        mode="list"; mode_token="$1"; ((mode_count+=1))
        ;;
      --add-connection|-a)
        mode="add"; mode_token="$1"; ((mode_count+=1))
        ;;
      --modify-connection|-m)
        mode="modify"; mode_token="$1"; ((mode_count+=1))
        ;;
      --delete-connection|-d)
        mode="delete"; mode_token="$1"; ((mode_count+=1))
        ;;
      --move-group|-mg)
        mode="move-group"; mode_token="$1"; ((mode_count+=1))
        ;;
      --modify-credential|-mc)
        mode="modify-credential"; mode_token="$1"; ((mode_count+=1))
        ;;
      --version)
        mode="version"; mode_token="$1"; ((mode_count+=1))
        ;;
      -*)
        # 전역 옵션 파싱 이후에도 남아있는 옵션은 "알 수 없는 옵션"으로 처리
        echo "Unknown option or command: $1" >&2
        exit 1
        ;;
      *)
        # 옵션이 아닌 토큰은 expr 후보로 누적
        expr_tokens+=("$1")
        ;;
    esac
    shift
  done

  # 모드 옵션은 1개만 허용(상호배타)
  if (( mode_count > 1 )); then
    echo "[ERROR] 모드 옵션은 1개만 사용할 수 있습니다. (mutual exclusive)" >&2
    echo "        입력된 모드 옵션이 2개 이상입니다." >&2
    exit 1
  fi

  # expr 구성(여러 토큰이면 공백으로 결합)
  local expr=""
  if [[ ${#expr_tokens[@]} -gt 0 ]]; then
    expr="${expr_tokens[*]}"
  fi

  # -n|--number 는 connect 전용 옵션이며, 다른 모드와는 상호배타적
  if [[ -n "${CONNECT_NUMBER:-}" && "$mode" != "connect" ]]; then
    echo "[ERROR] --number|-n 옵션은 접속(connect) 모드에서만 사용할 수 있습니다." >&2
    echo "        (다른 모드 옵션과는 함께 사용할 수 없습니다.)" >&2
    exit 1
  fi

  # (선택) -mc는 -s를 허용하지 않기로 한 정책을 런타임에서도 강제하려면 활성화
  # if [[ "$mode" == "modify-credential" && "$SHOW_CREDENTIAL" == "true" ]]; then
  #   echo "[ERROR] --modify-credential|-mc 모드에서는 --show-credential|-s 옵션을 사용할 수 없습니다." >&2
  #   exit 1
  # fi

  # 설정 및 보안 정보 기본 노출
  print_config_summary_banner

  # 2) 최종 실행
  case "$mode" in
    list)
      EXEC_CMD="list"
      cmd_list "$expr"
      ;;
    add)
      EXEC_CMD="add"
      cmd_add_connection
      ;;
    modify)
      EXEC_CMD="modify"
      cmd_modify_connection "$expr"
      ;;
    delete)
      EXEC_CMD="delete"
      cmd_delete_connection "$expr"
      ;;
    move-group)
      EXEC_CMD="move-group"
      cmd_move_group_connection "$expr"
      ;;
    modify-credential)
      EXEC_CMD="modify-credential"
      cmd_modify_credential "$expr"
      ;;
    version)
      echo "sshctl version ${APP_VERSION:-unknown}"
      return 0
      ;;
    connect|*)
      EXEC_CMD="connect"
      cmd_connect "$expr"
      ;;
  esac
}

main "$@"

exit 0
