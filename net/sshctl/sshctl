}

##
# sshctl -m|--modify-connection [expr] 명령을 구현하여 선택된 connection을 수정한다.
# Implement sshctl -m|--modify-connection [expr] and modify a selected connection.
#
# @param $1 {string|empty} query 검색식, 비어 있으면 전체 / search expression; empty for all
#
# @return {int} 성공 시 0, 선택/검증/저장 실패 시 비-0
#         0 on success; non-zero on selection/validation/save failures.
##
cmd_modify_connection() {
  ensure_config_file

  local query="${1:-}"
  local selected_json
  selected_json="$(select_connection_interactively "$query")" || return 1

  echo "-----------------------------------------------------------"

  local group name host_type host port username auth_type credential
  group="$(jq -r '.group' <<< "$selected_json")"
  name="$(jq -r '.name' <<< "$selected_json")"
  host_type="$(jq -r '.host_type' <<< "$selected_json")"
  host="$(jq -r '.host' <<< "$selected_json")"
  port="$(jq -r '.port // 22' <<< "$selected_json")"

  # -------------------------------
  # ★ username / credential 복호화 적용
  # -------------------------------
  username_enc="$(jq -r '.username' <<< "$selected_json")"
  username="$(decrypt_value_if_needed "$username_enc")"
  credential_enc="$(jq -r '.credential' <<< "$selected_json")"
  credential="$(decrypt_value_if_needed "$credential_enc")"

  auth_type="$(jq -r '.auth_type' <<< "$selected_json")"

  if [[ "$host" =~ ^(.+):([0-9]+)$ ]]; then
    host="${BASH_REMATCH[1]}"
    port="${BASH_REMATCH[2]}"
  fi

  local new_group new_name new_host_type new_host new_port new_username new_auth_type new_credential
  local host_input port_input tmp

  # group
  while true; do
    new_group="$(prompt_with_icon "📁" "group" "$group")"
    if [[ -z "$new_group" ]]; then
      new_group="$group"
    fi
    if validate_non_empty "group" "$new_group"; then
      break
    fi
  done

  # name
  while true; do
    new_name="$(prompt_with_icon "📛" "name" "$name")"
    if [[ -z "$new_name" ]]; then
      new_name="$name"
    fi
    if validate_non_empty "name" "$new_name"; then
      break
    fi
  done

  # host_type
  while true; do
    new_host_type="$(prompt_with_icon "🌐" "host_type (ipv4|ipv6|domain)" "$host_type")"
    if [[ -z "$new_host_type" ]]; then
      new_host_type="$host_type"
    fi
    if validate_host_type "$new_host_type"; then
      break
    fi
  done

  # host (+ optional port)
  while true; do
    host_input="$(prompt_with_icon "🌍" "host" "$host")"
    if [[ -z "$host_input" ]]; then
      host_input="$host"
    fi
    if [[ "$host_input" =~ ^(.+):([0-9]+)$ ]]; then
      new_host="${BASH_REMATCH[1]}"
      port_input="${BASH_REMATCH[2]}"
    else
      new_host="$host_input"
      port_input="$port"
    fi
    if ! validate_non_empty "host" "$new_host"; then
      continue
    fi
    if ! validate_host_by_type "$new_host_type" "$new_host"; then
      continue
    fi
    break
  done

  # port
  while true; do
    new_port="$(prompt_with_icon "🔌" "port" "$port_input")"
    if [[ -z "$new_port" ]]; then
      new_port="$port"
    fi
    if validate_port "$new_port"; then
      break
    fi
  done

  # username
  while true; do
    new_username="$(prompt_with_icon "👤" "username" "$username")"
    if [[ -z "$new_username" ]]; then
      new_username="$username"
    fi
    if validate_non_empty "username" "$new_username"; then
      break
    fi
  done

  # auth_type
  while true; do
    new_auth_type="$(prompt_with_icon "🔐" "auth_type (password|key)" "$auth_type")"
    if [[ -z "$new_auth_type" ]]; then
      new_auth_type="$auth_type"
    fi
    if validate_auth_type "$new_auth_type"; then
      break
    fi
  done

  # credential
  if [[ "$new_auth_type" == "password" ]]; then
    local old_pw="$credential"
    while true; do
      tmp="$(prompt_credential_with_icon "🔑" "password" "password" "$old_pw")"
      if [[ -z "$tmp" ]]; then
        new_credential="$old_pw"
        break
      fi
      new_credential="$tmp"
      break
    done
  else
    while true;
    do
      tmp="$(prompt_credential_with_icon "🔑" "key path" "key" "$credential")"
      if [[ -z "$tmp" ]];
      then
        new_credential="$(normalize_key_path_for_save "$credential")"
      else
        tmp="$(normalize_key_path_for_save "$tmp")"
        
        if ! validate_key_path_syntax "$tmp"; then
          continue
        fi
        new_credential="$tmp"
      fi
      if validate_non_empty "key path" "$new_credential";
      then
        break
      fi
    done
    printf '\n'
  fi

  echo "-----------------------------------------------------------"

  local new_json
  # -------------------------------
  # ★ 저장 직전 암호화 적용
  # -------------------------------
  new_username_enc="$(encrypt_value "$new_username")"
  new_credential_enc="$(encrypt_value "$new_credential")"

  new_json="$(update_connection_modify "$selected_json" \
                  "$new_group" "$new_name" "$new_host_type" "$new_host" "$new_port" \
                  "$new_username_enc" "$new_auth_type" "$new_credential_enc")"

  save_connections_json <<< "$new_json"

  echo "✨  수정 후 connection:"
  print_single_connection_from_fields "$new_group" "$new_name" "$new_host" "$new_port" "$new_username" "$new_credential"
}

##
# sshctl -mc|--modify-credential [expr] 명령을 구현하여 여러 connection의 password(credential)를 일괄 변경한다.
# Implement sshctl -mc|--modify-credential [expr] to bulk-update password credentials for multiple connections.
#
# @param $1 {string|empty} query 검색식, 비어 있으면 전체 / search expression; empty for all
#
# @return {int} 성공 시 0, 선택/검증/저장 실패 또는 취소 시 비-0
#         0 on success; non-zero on selection/validation/save failures or cancel.
##
cmd_modify_credential() {
  ensure_config_file

  local query="${1:-}"

  # 1) 대상 index(__idx) 목록 얻기 (password 방식만)
  local -a idxs=()
  local line
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    idxs+=( "$line" )
  done < <(select_indices_for_modify_credential "$query") || return 1

  if (( ${#idxs[@]} == 0 )); then
    return 1
  fi

  # 2) 새 password 입력 (기본값/이전값 없음)
  echo "-----------------------------------------------------------"
  local new_password=""
  while true; do
    new_password="$(prompt_credential_with_icon "🔑" "password" "password" "")"
    if validate_non_empty "password" "$new_password"; then
      break
    fi
  done
  echo "-----------------------------------------------------------"

  # 3) '민감정보' 암호화 적용
  local new_credential_enc
  new_credential_enc="$(encrypt_value "$new_password")"

  # 4) 선택된 여러 connection에 credential 적용 (단일 jq로 일괄 업데이트)
  local idxs_json
  idxs_json="$(printf '%s\n' "${idxs[@]}" | jq -R 'tonumber' | jq -s '.')"

  local new_json
  new_json="$(jq --argjson idxs "$idxs_json" --arg credential "$new_credential_enc" '
    reduce $idxs[] as $i (.;
      .connections[$i].credential = $credential
    )
  ' "$CONFIG_FILE")"

  save_connections_json <<< "$new_json"

  # 5) 변경된 connection 목록 출력
  echo "✨  수정 후 connection:"
  local preview_raw=""
  local idx
  for idx in "${idxs[@]}"; do
    local row
    row="$(jq -r --argjson i "$idx" '
      .connections
      | to_entries
      | .[$i]
      | "\(.value.group)\t\(.value.name)\t\(.value.host)\t\(.value.port // 22)\t\(.value.username)\t\(.value.credential)"
    ' "$CONFIG_FILE")"
    if [[ -n "$row" ]]; then
      preview_raw+="${row}"$'\n'
    fi
  done

  print_raw_as_table_no_index "$preview_raw"
}

select_indices_for_delete() {
  local query="$1"

  ensure_config_file
  local filter
  filter="$(build_search_filter "$query")"

  local raw
  raw="$(jq -r '
    .connections
    | to_entries
    | map(.key as $idx | .value + { "__idx": $idx })
    | map(select('"$filter"'))
    | sort_by([ (if .group == "default" then 0 else 1 end), .group, .name ])
    | .[]
    | "\(.group)\t\(.name)\t\(.host)\t\(.port // 22)\t\(.username)\t\(.credential)\t\(.__idx)"
  ' "$CONFIG_FILE")"

  if [[ -z "$raw" ]]; then
    echo "검색 결과가 없습니다." >&2
    return 1
  fi

  local idx_map=()
  local n=0 group name host port user cred idx

  if command -v column >/dev/null 2>&1; then
    local temp_buffer=""
    temp_buffer+="#\tGroup\tName\tHost\tPort\tUser\tCredential\n"

    while IFS=$'\t' read -r group name host port user cred idx; do
      if [[ -z "$group" && -z "$name" && -z "$host" && -z "$port" && -z "$user" && -z "$cred" ]]; then
        continue
      fi
      # -------------------------------
      # ★ 민감정보 복호화 적용
      # -------------------------------
      user_dec="$(decrypt_value_if_needed "$user")"
      cred_dec="$(decrypt_value_if_needed "$cred")"

      # credential 출력 정책은 복호화된 값 기준
      display_cred="$(format_credential_for_display "$cred_dec")"

      n=$((n+1))
      idx_map[$n]="$idx"

      local display_idx
      printf -v display_idx "%04d" "$n"
      display_cred="$(format_credential_for_display "$cred")"
      temp_buffer+="${display_idx}\t${group}\t${name}\t${host}\t${port}\t${user_dec}\t${display_cred}\n"
    done <<< "$raw"

    local rendered header_line data_lines header_len dash_line eq_line
    rendered="$(printf "%b" "$temp_buffer" | column -t -s $'\t')"
    header_line="$(printf '%s\n' "$rendered" | head -n 1)"
    data_lines="$(printf '%s\n' "$rendered" | tail -n +2)"
    header_len=${#header_line}
    printf -v dash_line '%*s' "$header_len" ''
    dash_line="${dash_line// /-}"
    printf -v eq_line '%*s' "$header_len" ''
    eq_line="${eq_line// /=}"

    printf '%s\n' "$eq_line"    >&2
    printf '%s\n' "$header_line" >&2
    printf '%s\n' "$dash_line"  >&2
    printf '%s\n' "$data_lines" >&2
    printf '%s\n' "$eq_line"    >&2
  else
    printf -- "%-4s\t%s\t%s\t%s\t%s\t%s\t%s\n" "#" "Group" "Name" "Host" "Port" "User" "Credential" >&2
    printf -- "%-4s\t%s\t%s\t%s\t%s\t%s\t%s\n" "----" "-----" "----" "----" "----" "----" "----------" >&2

    while IFS=$'\t' read -r group name host port user cred idx; do
      if [[ -z "$group" && -z "$name" && -z "$host" && -z "$port" && -z "$user" && -z "$cred" ]]; then
        continue
      fi

      # -------------------------------
      # ★ 민감정보 복호화 적용
      # -------------------------------
      user_dec="$(decrypt_value_if_needed "$user")"
      cred_dec="$(decrypt_value_if_needed "$cred")"

      # credential 출력 정책은 복호화된 값 기준
      display_cred="$(format_credential_for_display "$cred_dec")"

      n=$((n+1))
      idx_map[$n]="$idx"

      display_cred="$(format_credential_for_display "$cred")"
      local display_idx
      printf -v display_idx "%04d" "$n"
      printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
        "$display_idx" "$group" "$name" "$host" "$port" "$user_dec" "$display_cred" >&2
    done <<< "$raw"
  fi

  # 번호 입력 (쉼표 구분)
  local sel
  while true; do
    read -r -p "❓  삭제할 번호(#)를 입력하세요. (콤마(,)로 구분해서 입력) [1 ~ $n] : " sel
    sel="${sel//[[:space:]]/}"  # 공백 제거

    if [[ -z "$sel" ]]; then
      echo "❗  프로그램을 종료합니다." >&2
      return 1
    fi

    if ! [[ "$sel" =~ ^[0-9]+(,[0-9]+)*$ ]]; then
      echo "쉼표로 구분된 숫자만 입력하세요." >&2
      continue
    fi

    local -a nums=()
    IFS=',' read -r -a nums <<< "$sel"

    local ok=true
    local v
    for v in "${nums[@]}"; do
      if (( v < 1 || v > n )); then
        echo "범위를 벗어났습니다: $v (1~$n)" >&2
        ok=false
      fi
    done
    $ok && break
  done

  # 중복 제거 + idx_map → 실제 JSON index 로 변환
  local -A seen=()
  local -a real_idx=()
  local v
  for v in "${nums[@]}"; do
    if [[ -n "${seen[$v]:-}" ]]; then
      continue
    fi
    seen[$v]=1
    real_idx+=( "${idx_map[$v]}" )
  done

  # stdout: JSON index 들을 한 줄씩 반환
  printf '%s\n' "${real_idx[@]}"
}

##
# password 방식 connection 목록에서, 비밀번호(credential)를 일괄 변경할 대상 인덱스들을 선택한다.
# Select indices for bulk credential(password) update from password-based connections.
#
# @param $1 {string|empty} query 검색식, 비어 있으면 전체 / search expression; empty for all
#
# @return {int} 선택 완료 시 0, 취소/실패 시 비-0 / 0 on success; non-zero on cancel/failure.
# @return {string} STDOUT로 JSON index(__idx) 목록을 한 줄씩 출력 / prints JSON indices (__idx) one per line.
##
select_indices_for_modify_credential() {
  local query="$1"

  ensure_config_file
  local filter
  filter="$(build_search_filter "$query")"

  local raw
  raw="$(jq -r '
    .connections
    | to_entries
    | map(.key as $idx | .value + { "__idx": $idx })
    | map(select(('"$filter"') and (.auth_type == "password")))
    | sort_by([ (if .group == "default" then 0 else 1 end), .group, .name ])
    | .[]
    | "\(.group)\t\(.name)\t\(.host)\t\(.port // 22)\t\(.username)\t\(.credential)\t\(.__idx)"
  ' "$CONFIG_FILE")"

  if [[ -z "$raw" ]]; then
    echo "검색 결과가 없습니다. (password 방식 connection이 없습니다.)" >&2
    return 1
  fi

  local idx_map=()
  local n=0 group name host port user cred idx
  local user_dec cred_dec display_cred

  if command -v column >/dev/null 2>&1; then
    local temp_buffer=""
    temp_buffer+="#\tGroup\tName\tHost\tPort\tUser\tCredential\n"

    while IFS=$'\t' read -r group name host port user cred idx; do
      if [[ -z "$group" && -z "$name" && -z "$host" && -z "$port" && -z "$user" && -z "$cred" ]]; then
        continue
      fi

      user_dec="$(decrypt_value_if_needed "$user")"
      cred_dec="$(decrypt_value_if_needed "$cred")"      

      n=$((n+1))
      idx_map[$n]="$idx"

      local display_idx
      printf -v display_idx "%04d" "$n"
      temp_buffer+="${display_idx}\t${group}\t${name}\t${host}\t${port}\t${user_dec}\t${cred_dec}\n"
    done <<< "$raw"

    local rendered header_line data_lines header_len dash_line eq_line
    rendered="$(printf "%b" "$temp_buffer" | column -t -s $'\t')"
    header_line="$(printf '%s\n' "$rendered" | head -n 1)"
    data_lines="$(printf '%s\n' "$rendered" | tail -n +2)"
    header_len=${#header_line}
    printf -v dash_line '%*s' "$header_len" ''
    dash_line="${dash_line// /-}"
    printf -v eq_line '%*s' "$header_len" ''
    eq_line="${eq_line// /=}"

    printf '%s\n' "$eq_line"     >&2
    printf '%s\n' "$header_line" >&2
    printf '%s\n' "$dash_line"   >&2
    printf '%s\n' "$data_lines"  >&2
    printf '%s\n' "$eq_line"     >&2
  else
    printf -- "%-4s\t%s\t%s\t%s\t%s\t%s\t%s\n" "#" "Group" "Name" "Host" "Port" "User" "Credential" >&2
    printf -- "%-4s\t%s\t%s\t%s\t%s\t%s\t%s\n" "----" "-----" "----" "----" "----" "----" "----------" >&2

    while IFS=$'\t' read -r group name host port user cred idx; do
      if [[ -z "$group" && -z "$name" && -z "$host" && -z "$port" && -z "$user" && -z "$cred" ]]; then
        continue
      fi

      user_dec="$(decrypt_value_if_needed "$user")"
      cred_dec="$(decrypt_value_if_needed "$cred")"
      display_cred="$(format_credential_for_display "$cred_dec")"

      n=$((n+1))
      idx_map[$n]="$idx"

      local display_idx
      printf -v display_idx "%04d" "$n"
      printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
        "$display_idx" "$group" "$name" "$host" "$port" "$user_dec" "$display_cred" >&2
    done <<< "$raw"
  fi

  local sel
  while true; do
    read -r -p "❓  비밀번호를 변경할 번호(#)를 입력하세요. (콤마(,)로 구분해서 입력) [1 ~ $n] : " sel
    sel="${sel//[[:space:]]/}"

    if [[ -z "$sel" ]]; then
      echo "❗  프로그램을 종료합니다." >&2
      return 1
    fi

    if ! [[ "$sel" =~ ^[0-9]+(,[0-9]+)*$ ]]; then
      echo "쉼표로 구분된 숫자만 입력하세요." >&2
      continue
    fi

    local -a nums=()
    IFS=',' read -r -a nums <<< "$sel"

    local ok=true
    local v
    for v in "${nums[@]}"; do
      if (( v < 1 || v > n )); then
        echo "범위를 벗어났습니다: $v (1~$n)" >&2
        ok=false
      fi
    done
    $ok && break
  done

  local -A seen=()
  local -a real_idx=()
  local v
  for v in "${nums[@]}"; do
    if [[ -n "${seen[$v]:-}" ]]; then
      continue
    fi
    seen[$v]=1
    real_idx+=( "${idx_map[$v]}" )
  done

  printf '%s\n' "${real_idx[@]}"
}

##
# sshctl -d|--delete-connection [expr] 명령을 구현하여 선택된 connection을 삭제한다.
# Implement sshctl -d|--delete-connection [expr] and delete a selected connection.
#
# @param $1 {string|empty} query 검색식, 비어 있으면 전체 / search expression; empty for all
#
# @return {int} 삭제 완료 시 0, 선택/확인/저장 실패 또는 취소 시 비-0
#         0 on successful deletion; non-zero on failure or cancel.
##
cmd_delete_connection() {
  ensure_config_file

  local query="${1:-}"

  # 1) 삭제 대상 index (JSON 상의 __idx) 목록 얻기
  local -a idxs=()
  local line
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    idxs+=( "$line" )
  done < <(select_indices_for_delete "$query") || return 1

  if (( ${#idxs[@]} == 0 )); then
    #echo "선택된 항목이 없습니다. 삭제를 취소합니다." >&2
    return 1
  fi

  # 2) "삭제 대상:" 미리보기
  echo "삭제 대상:"
  local preview_raw=""
  local idx
  for idx in "${idxs[@]}"; do
    local row
    row="$(jq -r --argjson i "$idx" '
      .connections
      | to_entries
      | .[$i]
      | "\(.value.group)\t\(.value.name)\t\(.value.host)\t\(.value.port // 22)\t\(.value.username)\t\(.value.credential)"
    ' "$CONFIG_FILE")"
    if [[ -n "$row" ]]; then
      preview_raw+="${row}"$'\n'
    fi
  done
  print_raw_as_table_no_index "$preview_raw"

  # 3) 최종 확인
  local answer
  read -r -p "정말 삭제하시겠습니까? (y/N): " answer
  case "$answer" in
    y|Y|yes|YES)
      # 4) 큰 index부터 삭제 (앞쪽 index 영향 최소화)
      local sorted
      sorted="$(printf '%s\n' "${idxs[@]}" | sort -rn)"

      local i
      for i in $sorted; do
        local selected_json
        selected_json="$(jq -c --argjson j "$i" '
          .connections
          | to_entries
          | .[$j]
          | { __idx: .key } + .value
        ' "$CONFIG_FILE")" || continue

        local new_json
        new_json="$(update_connection_delete "$selected_json")"
        save_connections_json <<< "$new_json"
      done

      echo "삭제 완료."
      ;;
    *)
      echo "삭제 취소."
      ;;
  esac
}

##
# sshctl -mg|--move-group [expr] 명령을 구현하여 선택된 connection의 group을 변경한다.
# Implement sshctl -mg|--move-group [expr] and change the group of a selected connection.
#
# @param $1 {string|empty} query 검색식, 비어 있으면 전체 / search expression; empty for all
#
# @return {int} 성공 시 0, 선택/검증/저장 실패 시 비-0
#         0 on success; non-zero on selection/validation/save failures.
##
cmd_move_group_connection() {
  ensure_config_file

  local query="${1:-}"
  local selected_json
  selected_json="$(select_connection_interactively "$query")" || return 1

  echo "-----------------------------------------------------------"

  local current_group idx
  current_group="$(jq -r '.group' <<< "$selected_json")"
  idx="$(jq -r '.__idx'  <<< "$selected_json")"

  echo "현재 group: ${current_group}"

  local new_group
  while true; do
    new_group="$(prompt_with_icon "📁" "새 group" "$current_group")"
    if [[ -z "$new_group" ]]; then
      new_group="$current_group"
    fi
    if validate_non_empty "group" "$new_group"; then
      break
    fi
  done

  echo "-----------------------------------------------------------"

  local new_json
  new_json="$(update_connection_move_group "$selected_json" "$new_group")"
  save_connections_json <<< "$new_json"

  echo "group 변경 완료: ${current_group} → ${new_group}"
  echo "변경된 connection:"

  local updated_json
  updated_json="$(jq -c --argjson i "$idx" '
    .connections
    | to_entries
    | .[$i]
    | { __idx: .key } + .value
  ' "$CONFIG_FILE")"
  print_connection_preview_from_json "$updated_json"
}

