##
# 검색식으로 connection 후보를 필터링하고, N번째 항목을 선택하여 JSON을 반환한다.
# Filter connection candidates by query and select the N-th item, returning it as JSON.
#
# @param $1 {string} query 검색식 (빈 문자열이면 전체) / search query; empty for all
# @param $2 {int} number 1-based 번호(#) / 1-based index
#
# @return {string} STDOUT로 { __idx, group, name, host, port, username, auth_type, credential } JSON 출력
#         prints selected connection JSON (including __idx) to STDOUT.
# @return {int} 성공 시 0, 실패 시 1 / 0 on success, 1 on failure.
##
select_connection_by_number() {
  local query="${1:-}"
  local number="${2:-}"

  if [[ -z "$number" ]]; then
    echo "[ERROR] --number|-n 옵션에는 숫자 값이 필요합니다." >&2
    return 1
  fi
  if ! [[ "$number" =~ ^[0-9]+$ ]]; then
    echo "[ERROR] --number|-n 값은 숫자여야 합니다: $number" >&2
    return 1
  fi

  ensure_config_file
  local filter
  filter="$(build_search_filter "$query")"

  local candidates
  candidates="$(jq -c '     .connections     | to_entries     | map(.key as $idx | .value + {"__idx": $idx })     | map(select('"$filter"'))     | sort_by([ (if .group == "default" then 0 else 1 end), .group, .name ])   ' "$CONFIG_FILE")"

  local total
  total="$(jq -r 'length' <<< "$candidates")"
  if [[ "$total" == "0" ]]; then
    echo "검색 결과가 없습니다." >&2
    return 1
  fi

  if (( number < 1 || number > total )); then
    echo "[ERROR] 번호(#) 값이 범위를 벗어났습니다: $number (허용: 1 ~ $total)" >&2
    return 1
  fi

  local idx0=$((number - 1))
  local selected
  selected="$(jq -c --argjson i "$idx0" '.[$i]' <<< "$candidates")"

  local group name host port user cred
  group="$(jq -r '.group' <<< "$selected")"
  name="$(jq -r '.name' <<< "$selected")"
  host="$(jq -r '.host' <<< "$selected")"
  port="$(jq -r '.port // 22' <<< "$selected")"
  user="$(jq -r '.username' <<< "$selected")"
  cred="$(jq -r '.credential' <<< "$selected")"

  # 선택된 항목 1건만 출력 (배너 없음)
  print_single_connection_no_banner "$group" "$name" "$host" "$port" "$user" "$cred" >&2

  # cmd_connect의 출력과 구분을 위해 1줄 띄움
  echo >&2

  printf '%s' "$selected"
  return 0
}

select_connection_interactively() {
  local query="$1"

  ensure_config_file
  local filter
  filter="$(build_search_filter "$query")"

  local raw
  raw="$(jq -r '
    .connections
    | to_entries
    | map(.key as $idx | .value + { "__idx": $idx })
    | map(select('"$filter"'))
    | sort_by([ (if .group == "default" then 0 else 1 end), .group, .name ])
    | .[]
    | "\(.group)\t\(.name)\t\(.host)\t\(.port // 22)\t\(.username)\t\(.credential)\t\(.__idx)"
  ' "$CONFIG_FILE")"

  if [[ -z "$raw" ]]; then
    echo "검색 결과가 없습니다." >&2
    return 1
  fi

  local idx_map=()
  local n=0
  local group name host port user cred idx display_cred

  if command -v column >/dev/null 2>&1; then
    local temp_buffer=""
    temp_buffer+="#\tGroup\tName\tHost\tPort\tUser\tCredential\n"

    while IFS=$'\t' read -r group name host port user cred idx; do
      if [[ -z "$group" && -z "$name" && -z "$host" && -z "$port" && -z "$user" && -z "$cred" ]]; then
        continue
      fi

      # 보여줄 데이터는 decript
      user_dec="$(decrypt_value_if_needed "$user")"
      cred_dec="$(decrypt_value_if_needed "$cred")"

      # credential 출력 정책은 복호화된 값 기준
      display_cred="$(format_credential_for_display "$cred_dec")"

      n=$((n+1))
      idx_map[$n]="$idx"

      local display_idx
      printf -v display_idx "%04d" "$n"
      temp_buffer+="${display_idx}\t${group}\t${name}\t${host}\t${port}\t${user_dec}\t${display_cred}\n"
    done <<< "$raw"

    local rendered header_line data_lines header_len separator eq_line
    rendered="$(printf "%b" "$temp_buffer" | column -t -s $'\t')"
    header_line="$(printf '%s\n' "$rendered" | head -n 1)"
    data_lines="$(printf '%s\n' "$rendered" | tail -n +2)"
    header_len=${#header_line}
    printf -v separator '%*s' "$header_len" ''
    separator="${separator// /-}"
    printf -v eq_line '%*s' "$header_len" ''
    eq_line="${eq_line// /=}"

    printf '%s\n' "$eq_line"    >&2
    printf '%s\n' "$header_line" >&2
    printf '%s\n' "$separator"  >&2
    printf '%s\n' "$data_lines" >&2
    printf '%s\n' "$eq_line"    >&2
  else
    printf -- "%-4s\t%s\t%s\t%s\t%s\t%s\t%s\n" "#" "Group" "Name" "Host" "Port" "User" "Credential" >&2
    printf -- "%-4s\t%s\t%s\t%s\t%s\t%s\t%s\n" "----" "-----" "----" "----" "----" "----" "----------" >&2

    while IFS=$'\t' read -r group name host port user cred idx; do
      if [[ -z "$group" && -z "$name" && -z "$host" && -z "$port" && -z "$user" && -z "$cred" ]]; then
        continue
      fi

      # 보여줄 데이터는 decript
      user_dec="$(decrypt_value_if_needed "$user")"
      cred_dec="$(decrypt_value_if_needed "$cred")"

      # credential 출력 정책은 복호화된 값 기준
      display_cred="$(format_credential_for_display "$cred_dec")"

      n=$((n+1))
      idx_map[$n]="$idx"

      local display_idx
      printf -v display_idx "%04d" "$n"
      display_cred="$(format_credential_for_display "$cred")"
      printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
        "$display_idx" "$group" "$name" "$host" "$port" "$user_dec" "$display_cred" >&2
    done <<< "$raw"
  fi

  local sel
  local prompt_msg="✨  번호(#)를 선택하세요 [1 ~ $n]: "
  while true; do
    read -r -p "$prompt_msg" sel
    if [[ -z "$sel" ]]; then
      echo "❗  프로그램을 종료합니다." >&2
      return 1
    fi
    if ! [[ "$sel" =~ ^[0-9]+$ ]] || (( sel < 1 || sel > n )); then
      prompt_msg="❗  입력한 값이 올바르지 않습니다. 번호(#)를 선택하세요 [1 ~ $n]: "
      continue
    fi
    break
  done

  local selected_idx="${idx_map[$sel]}"

  jq -c --argjson i "$selected_idx" '
    .connections
    | to_entries
    | .[$i]
    | { __idx: .key } + .value
  ' "$CONFIG_FILE"
}

# -----------------------------------------------------------------------------
# UTF-8 문자를 1개 읽는다. (한국어 포함)
# - 한국어/English: read one UTF-8 character from stdin
# @return {string} 읽은 문자 1개를 echo 로 반환. Enter 시 빈 문자열 반환.
# -----------------------------------------------------------------------------
_read_utf8_char() {
  local c
  IFS= read -r -s -n 1 c || return 1

  # Enter
  if [[ "$c" == $'\n' || "$c" == $'\r' ]]; then
    echo ""
    return 0
  fi

  # 일반 ASCII
  local ord
  ord=$(printf '%d' "'$c" 2>/dev/null)
  if [[ -z "$ord" ]]; then
    # 일부 환경에서 printf '%d' "'$c" 가 비정상인 경우가 있어 fallback
    echo "$c"
    return 0
  fi

  # UTF-8 멀티바이트 처리
  local need=0
  if (( ord >= 0 && ord <= 127 )); then
    need=0
  elif (( ord >= 192 && ord <= 223 )); then
    need=1
  elif (( ord >= 224 && ord <= 239 )); then
    need=2
  elif (( ord >= 240 && ord <= 247 )); then
    need=3
  else
    need=0
  fi

  if (( need > 0 )); then
    local rest=""
    IFS= read -r -s -n "$need" rest || true
    echo "${c}${rest}"
  else
    echo "$c"
  fi

  return 0
}

# -----------------------------------------------------------------------------
# UTF-8 안전한 한 줄 입력기 (Backspace/CTRL+U 지원)
# - 한국어/English: line editor that redraws line, safe for UTF-8
#
# @param $1 {string} prompt 입력 프롬프트(ASCII 권장). 예: "> "
# @param $2 {string} default 기본값(Enter 시 적용)
# @return {string} 입력 문자열을 echo 로 반환
# -----------------------------------------------------------------------------
read_line_utf8() {
  local prompt="$1"
  local default_value="${2:-}"
  local buf=""
  local ch

  local EL=$'\033[K'
  if command -v tput >/dev/null 2>&1; then
    EL="$(tput el)"
  fi

  local old_stty
  old_stty="$(stty -g 2>/dev/null)"
  stty -echo 2>/dev/null

  # 최초 1회는 prompt만 출력 (여기서 라인을 지우지 않음)
  printf '%s' "$prompt" >&2

  while true; do
    IFS= read -r -s -n 1 ch || break

    # Enter만 눌렀을 때: bash read는 newline을 delimiter로 소비해서 ch가 빈 문자열이 됨
    # => 빈 문자열도 Enter로 간주하고 종료
    if [[ -z "$ch" || "$ch" == $'\n' || "$ch" == $'\r' ]]; then
      break
    fi

    if [[ "$ch" == $'\x7f' || "$ch" == $'\x08' ]]; then
      if [[ -n "$buf" ]]; then
        buf="${buf%?}"  # UTF-8 안전: 마지막 문자 1개 제거
      fi
      # prompt는 항상 유지하고, 잔상만 제거
      printf '\r%s%s%s' "$prompt" "$buf" "$EL" >&2
      continue
    fi

    if [[ "$ch" == $'\x15' ]]; then
      buf=""
      printf '\r%s%s%s' "$prompt" "$buf" "$EL" >&2
      continue
    fi

    buf+="$ch"
    printf '\r%s%s%s' "$prompt" "$buf" "$EL" >&2
  done

  stty "$old_stty" 2>/dev/null
  printf '\n' >&2

  if [[ -z "$buf" && -n "$default_value" ]]; then
    buf="$default_value"
  fi

  printf '%s' "$buf"
  return 0
}

# -----------------------------------------------------------------------------
# UTF-8 안전한 비밀번호 입력기 (마스킹 출력)
# - 한국어/English: masked password input (****), safe for UTF-8 editing
#
# @param $1 {string} prompt 입력 프롬프트 (예: "       > [****]: ")
# @param $2 {string} default_value 기본값(Enter 시 유지할 값). 빈 문자열이면 Enter는 빈 값.
# @return {string} 입력 문자열(평문)을 echo로 반환
# -----------------------------------------------------------------------------
_read_password_utf8_masked() {
  local prompt="$1"
  local default_value="${2:-}"
  local buf=""
  local ch

  local EL=$'\033[K'
  if command -v tput >/dev/null 2>&1; then
    EL="$(tput el)"
  fi

  local old_stty
  old_stty="$(stty -g 2>/dev/null)"

  # 혹시 예외/중단 시에도 stty 복구되도록 (함수 범위에서만)
  trap 'stty "$old_stty" 2>/dev/null' INT TERM

  stty -echo 2>/dev/null

  # 최초 프롬프트 출력
  printf '%s' "$prompt" >&2

  while true; do
    IFS= read -r -s -n 1 ch || break

    # Enter 처리 (빈 문자열도 Enter)
    if [[ -z "$ch" || "$ch" == $'\n' || "$ch" == $'\r' ]]; then
      break
    fi

    # Backspace (DEL/BS)
    if [[ "$ch" == $'\x7f' || "$ch" == $'\x08' ]]; then
      if [[ -n "$buf" ]]; then
        buf="${buf%?}"  # UTF-8 문자 단위 삭제
      fi

      # 마스킹 문자열 재생성
      local stars=""
      if [[ -n "$buf" ]]; then
        stars="$(printf '%*s' "${#buf}" '' | tr ' ' '*')"
      fi

      printf '\r%s%s%s' "$prompt" "$stars" "$EL" >&2
      continue
    fi

    # Ctrl+U: 라인 전체 삭제
    if [[ "$ch" == $'\x15' ]]; then
      buf=""
      printf '\r%s%s%s' "$prompt" "" "$EL" >&2
      continue
    fi

    # 일반 문자 추가
    buf+="$ch"

    local stars=""
    stars="$(printf '%*s' "${#buf}" '' | tr ' ' '*')"
    printf '\r%s%s%s' "$prompt" "$stars" "$EL" >&2
  done

  stty "$old_stty" 2>/dev/null
  trap - INT TERM
  printf '\n' >&2

  # Enter만 눌렀고 default_value가 있으면 default 적용(=기존 값 유지)
  if [[ -z "$buf" && -n "$default_value" ]]; then
    buf="$default_value"
  fi

  printf '%s' "$buf"
  return 0
}

# -----------------------------------------------------------------------------
# credential 입력 프롬프트 (password/key 공통)
# - 한국어/English: unified credential prompt for password/key
#
# @param $1 {string} icon  아이콘(예: 🔑)
# @param $2 {string} field 필드명(예: password, key path)
# @param $3 {string} auth_type "password" | "key"
# @param $4 {string} current 기존 값 (password의 경우 실제 값은 숨기되 Enter=keep)
#
# @return {string} 입력 결과를 echo로 반환
#   - password: 평문 반환(표시는 ****), Enter면 기존 값 유지
#   - key: 경로 문자열 반환, Enter면 기존 값 유지
# -----------------------------------------------------------------------------
prompt_credential_with_icon() {
  local icon="$1"
  local field="$2"
  local auth_type="$3"
  local current="${4:-}"
  local input input_prompt

  # 안내 라인 (이모지 포함, 편집 없음)
  printf '\r\033[K' >&2
  printf " * %s  '%s' 정보를 입력하세요.\n" "${icon}" "${field}" >&2

  if [[ "$auth_type" == "password" ]]; then
    # 기존 UX 유지: > [****]:
    input_prompt="       > "
    #input_prompt+="[****]: "
    input_prompt+="[${current}]: "

    # 마스킹 입력기 사용 (Enter 시 기존 값 유지)
    input="$(_read_password_utf8_masked "$input_prompt" "$current")"
    printf '%s' "$input"
    return 0
  fi

  # key path: 기존 UX 유지: > [<path>]:
  input_prompt="       > "
  if [[ -n "$current" ]]; then
    input_prompt+="[${current}]: "
  else
    input_prompt+=": "
  fi

  # key path는 일반 입력 (UTF-8 안전)
  input="$(read_line_utf8 "$input_prompt" "$current")"
  printf '%s' "$input"
  return 0
}

##
# 아이콘과 필드명을 PROMPT_LABEL_WIDTH 기준으로 정렬하여 입력을 받는다.
# Prompt with an icon and field name aligned by PROMPT_LABEL_WIDTH.
#
# history
# - 20251216: 글자 밀림 수정
#
# @param $1 {string} icon 프롬프트에 사용할 아이콘 / icon to display
# @param $2 {string} field 필드 이름 / field name
# @param $3 {string|empty} current 현재/기본 값 / current/default value
#
# @return {string} STDOUT로 최종 입력값 출력 / prints final input value to STDOUT.
# @return {int} 항상 0 / always 0.
##
prompt_with_icon() {
  local icon="$1"
  local field="$2"
  local current="${3:-}"
  local raw label input input_prompt

  raw="${icon}  ${field}"
  printf -v label "%-*s" "$PROMPT_LABEL_WIDTH" "$raw"

  # 라인 잔상 방지
  printf '\r\033[K' >&2

  # 1) 안내 라인(이모지 포함)은 별도 출력 (여기서는 커서 편집이 없음)
  if [[ -n "$current" ]]; then
    printf " * %s  '%s' 정보를 입력하세요.\n" "${icon}" "${field}" >&2
  else
    printf " * %s  '%s' 정보를 입력하세요.\n" "${icon}" "${field}" >&2
  fi

  # 2) 실제 입력 라인(타이핑하는 줄) - 기존 UX 유지: > [default]:
  input_prompt="       > "
  if [[ -n "$current" ]]; then
    input_prompt+="[${current}]: "
  else
    input_prompt+=": "
  fi

  # UTF-8 안전 입력기 적용 (한글 입력/삭제 시 잔상 및 커서 문제 완화)
  # Enter 입력 시 default(current) 값 적용
  input="$(read_line_utf8 "$input_prompt" "$current")"

  printf '%s' "$input"
}

