    echo "🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐" >&2
    echo "🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐" >&2
    echo "🔐🔐🔐                                          🔐🔐🔐" >&2
    echo "🔐🔐🔐 안심: 'OpenSSH Key 인증방식' 접속입니다. 🔐🔐🔐" >&2
    echo "🔐🔐🔐                                          🔐🔐🔐" >&2
    echo "🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐🔐" >&2
