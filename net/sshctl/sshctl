##
# 새 SSH connection 정보를 인터랙티브하게 입력 후 configuration에 추가한다.
# Add a new SSH connection interactively and append it to configuration.
#
# @param $1 없음 (모든 입력은 프롬프트로 받음) / none (all inputs are prompted interactively)
#
# @return {int} 성공 시 0, 검증/저장 실패 시 비-0
#         0 on success; non-zero on validation or save failures.
##
cmd_add_connection() {
  ensure_config_file

  log INFO "새 connection 정보를 입력합니다."

  echo "-----------------------------------------------------------"

  local group name host_type host port username auth_type credential host_input port_input

  # group
  while true; do
    group="$(prompt_with_icon "📁" "group" "default")"
    if validate_non_empty "group" "$group"; then
      break
    fi
  done

  # name
  while true; do
    name="$(prompt_with_icon "📛" "name" "")"
    if validate_non_empty "name" "$name"; then
      break
    fi
  done

  # host_type
  while true; do
    host_type="$(prompt_with_icon "🌐" "host_type (ipv4|ipv6|domain)" "ipv4")"
    if validate_host_type "$host_type"; then
      break
    fi
  done

  # host (+ optional port)
  while true; do
    host_input="$(prompt_with_icon "🌍" "host" "")"
    if [[ "$host_input" =~ ^(.+):([0-9]+)$ ]]; then
      host="${BASH_REMATCH[1]}"
      port_input="${BASH_REMATCH[2]}"
    else
      host="$host_input"
      port_input="22"
    fi
    if ! validate_non_empty "host" "$host"; then
      continue
    fi
    if ! validate_host_by_type "$host_type" "$host"; then
      continue
    fi
    break
  done

  # port
  while true; do
    port="$(prompt_with_icon "🔌" "port" "$port_input")"
    if validate_port "$port"; then
      break
    fi
  done

  # username
  while true; do
    username="$(prompt_with_icon "👤" "username" "")"
    if validate_non_empty "username" "$username"; then
      break
    fi
  done

  # auth_type
  while true; do
    auth_type="$(prompt_with_icon "🔐" "auth_type (password|key)" "password")"
    if validate_auth_type "$auth_type"; then
      break
    fi
  done

  # credential
  if [[ "$auth_type" == "password" ]]; then
    while true; do
      credential="$(prompt_credential_with_icon "🔑" "password" "password" "")"
      if validate_non_empty "password" "$credential"; then
        break
      fi
    done
  else
    while true;
    do
      credential="$(prompt_credential_with_icon "🔑" "key path" "key" "")"
      
      credential="$(normalize_key_path_for_save "$credential")"
      
      if ! validate_key_path_syntax "$credential"; then
        continue
      fi
      if validate_non_empty "key path" "$credential";
      then
        break
      fi
    done
  fi

  echo "-----------------------------------------------------------"

  # '민감정보' 암호화 적용
  username_enc="$(encrypt_value "$username")"
  credential_enc="$(encrypt_value "$credential")"

  local new_json
  new_json="$(jq --arg group "$group" \
                 --arg name "$name" \
                 --arg host_type "$host_type" \
                 --arg host "$host" \
                 --arg port "$port" \
                 --arg username "$username_enc" \
                 --arg auth_type "$auth_type" \
                 --arg credential "$credential_enc" \
                 '
    .connections += [{
      "group": $group,
      "name": $name,
      "host_type": $host_type,
      "host": $host,
      "port": ($port | tonumber),
      "username": $username,
      "auth_type": $auth_type,
      "credential": $credential
    }]
  ' "$CONFIG_FILE")"

  save_connections_json <<< "$new_json"

  local raw_line="${group}\t${name}\t${host}\t${port}\t${username}\t${credential}"
  local temp_buffer="Group\tName\tHost\tPort\tUser\tCredential\n${raw_line}\n"

  if command -v column >/dev/null 2>&1; then
    local rendered header_line data_lines header_len eq_line dash_line
    rendered="$(printf "%b" "$temp_buffer" | column -t -s $'\t')"
    header_line="$(printf '%s\n' "$rendered" | head -n 1)"
    data_lines="$(printf '%s\n' "$rendered" | tail -n +2)"
    header_len=${#header_line}
    printf -v eq_line '%*s' "$header_len" ''
    eq_line="${eq_line// /=}"
    printf -v dash_line '%*s' "$header_len" ''
    dash_line="${dash_line// /-}"

    echo "$eq_line"
    echo "생성된 connection:"
    echo "$header_line"
    echo "$dash_line"
    echo "$data_lines"
  else
    echo "=============================="
    echo "생성된 connection:"
    print_single_connection_from_fields "$group" "$name" "$host" "$port" "$username" "$credential"
  fi

  # auth_type 이 password 인 경우, configuration 저장 후 sshpass 자동 설치 시도
  if [[ "$auth_type" == "password" ]]; then
    if ! command -v sshpass >/dev/null 2>&1; then
      echo "INFO: auth_type=password 이므로 sshpass 설치를 시도합니다." >&2
      if ! install_sshpass_if_missing; then
        echo "WARN: sshpass 설치에 실패했습니다. 이후 password 기반 접속 시 sshpass 가 필요합니다." >&2
      fi
    fi
  fi
}

##
# 기본/검색 expr 에 따라 실제 SSH 접속을 수행한다.
# Perform actual SSH connection based on optional search expr (default/select & connect).
#
# @param $1 {string|empty} query 검색식, 비어 있으면 전체 / search expression; empty for all
#
# @return {int} password 모드에서는 ssh 반환 코드, key 모드에서는 exec ssh 후 복귀하지 않음.
#         In password mode: ssh exit code; in key mode: exec ssh (no return).
##
cmd_connect() {
  ensure_config_file

  local query="${1:-}"
  local selected_json
  if [[ -n "${CONNECT_NUMBER:-}" ]]; then
    selected_json="$(select_connection_by_number "$query" "$CONNECT_NUMBER")" || return 1
