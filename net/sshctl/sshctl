    echo "❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗" >&2
    echo "❗❗❗                                          ❗❗❗" >&2
    echo "❗❗❗ 경고: sshpass + password 방식 접속입니다 ❗❗❗" >&2
    echo "❗❗❗                                          ❗❗❗" >&2
    echo "❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗" >&2
    echo "❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗❗" >&2
    echo 
    sshpass -p "$credential" ssh "${ssh_opts[@]}" -p "$port" "${username}@${host}"
  else
    # 런타임 실시간 동적 확장 함수 연동
    local expanded_credential
    expanded_credential="$(expand_key_path_runtime "$credential")"
    
    if [[ ! -f "$expanded_credential" ]]; then
      die "key file not found: $expanded_credential"
    fi
