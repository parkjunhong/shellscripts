FILENAME="$(basename "$0")"

# 기본 설정 파일 경로 (Default configuration file path)
DEFAULT_CONFIG_DIR="${HOME}/.sshctl"
DEFAULT_CONFIG_FILE="${DEFAULT_CONFIG_DIR}/configuration"

# 설정 디렉토리 / 파일
CONFIG_DIR="${HOME}/.sshctl"
CONFIG_FILE="${CONFIG_DIR}/configuration.conf"
CONFIG_VERSION="1.0"

# masterkey (OpenSSH private key) 기본 경로 및 실제 사용 경로
MASTERKEY_DEFAULT="${HOME}/.sshctl/masterkey.pem"
MASTERKEY_FILE="${MASTERKEY_DEFAULT}"

# 프롬프트 라벨 폭 (아이콘+필드명 고정 폭)
PROMPT_LABEL_WIDTH=32

# credential 표시 제어 (기본: 마스킹, --show-credential/-s 로 평문 표시)
SHOW_CREDENTIAL="false"

# 바로 접속 번호 지정 (connect mode only)
# - 한국어/English: direct connect by selecting N-th item from filtered list
CONNECT_NUMBER=""

# =======================================
# help / usage
# =======================================

##
# sshctl 전체 사용법과 에러 정보를 출력한다.
# Print overall usage and diagnostic error information for sshctl.
#
# @param $1 {string|empty} 에러/원인 메시지 (선택) / cause message (optional)
# @param $2 {int|empty} 에러 발생 라인 번호 (선택) / line number where error occurred (optional)
#
# @return {int} 항상 0을 반환하지만, 보통 die()에서 호출된 뒤 프로세스는 exit 1로 종료됨.
#         Always returns 0; typically invoked by die() and process exits with 1 afterwards.
##
help() {
  # $1: cause message (optional)
  # $2: line number (optional)
  if [ -n "${1:-}" ]; then
    local indent=10
    local formatl=" - %-"$indent"s: %s\n"
    local formatr=" - %"$indent"s: %s\n"
    echo
    echo "================================================================================"
    printf "$formatl" "filename" "$FILENAME"
    printf "$formatl" "line" "${2:-0}"
    printf "$formatl" "callstack"
    local idx=1
    for func in "${FUNCNAME[@]:1}"
    do
      printf "$formatr" "[$idx]" "$func"
      ((idx++))
    done
    printf "$formatl" "cause" "$1"
    echo "================================================================================"
  fi
  echo
  cat <<EOF
사용법 (Usage):
  sshctl [global-options]               # 기본: 전체 목록에서 선택 후 접속
  sshctl [global-options] <expr>        # expr 로 필터링 후 선택/접속
  sshctl [global-options] <expr> -n|--number <N>
  sshctl [global-options] -n|--number <N> [expr]
  sshctl [global-options] -l|--list-all [expr]
  sshctl [global-options] -a|--add-connection
  sshctl [global-options] -m|--modify-connection [expr]
  sshctl [global-options] -d|--delete-connection [expr]
  sshctl [global-options] -mg|--move-group [expr]
  sshctl [global-options] -mc|--modify-credential [expr]

Global options:
  --config <file>
    - 설정 파일 경로를 지정합니다. 파일이 존재하면 해당 파일을 설정으로 사용합니다.
    - 파일이 없으면 경고 메시지를 출력하고 기본 경로(${DEFAULT_CONFIG_FILE})를 사용합니다.

  --masterkey <file>
    - '민감정보'(username, credential) 암/복호화에 사용될 OpenSSH private key 경로를 지정합니다.
    - 지정하지 않으면 기본값(${MASTERKEY_DEFAULT})을 사용합니다.

  -s, --show-credential
    - 목록/미리보기에서 credential 값을 평문으로 출력합니다.
    - 기본값은 항상 "****************" (16개 별표)로 마스킹합니다.

  -n, --number <N>
    - 바로 접속 기능에서 사용할 번호(#)를 지정합니다.
    - 이 옵션은 connect 동작에서만 유효하며, 목록을 출력하지 않고 N번째 항목으로 바로 접속합니다.
    - 다른 모드 옵션(-l/-a/-m/-d/-mg/-mc)과는 함께 사용할 수 없습니다.

Commands:
  -l, --list-all [expr]
    - SSH connection 목록을 조회합니다.
    - 검색식 expr 이 있는 경우, expr 에 해당하는 connection 만 필터링합니다.

  -a, --add-connection
    - 새로운 SSH connection 정보를 추가합니다 (interactive).
    - auth_type 이 'key' 인 경우, key path 는 입력값 그대로 저장됩니다. 접속 시점에 ~, \$VAR, \${VAR} 만 해석합니다.
    - auth_type 이 'password' 인 경우, connection 저장 후 sshpass 가 없으면 자동 설치를 시도합니다.

  -m, --modify-connection [expr]
    - 검색식 expr 으로 connection 을 고른 뒤, 선택된 connection 을 수정합니다.
    - 수정 후 결과 connection 1건을 표 형태로 보여줍니다.

  -d, --delete-connection [expr]
    - 검색식 expr 으로 connection 을 고른 뒤, 삭제 대상 connection 1건을 표로 출력합니다.
    - 사용자가 y/yes 로 확인하면 실제로 삭제합니다.

  -mg, --move-group [expr]
    - 검색식 expr 으로 connection 을 고른 뒤, 그룹(group) 값을 변경합니다.

  -mc, --modify-credential [expr]
    - 검색식 expr 으로 password 방식 connection 목록을 고른 뒤, 번호(#)를 콤마(,)로 여러 개 선택합니다.
      - 'credential' 정보는 평문(plain text)로 보여줍니다.
    - 입력한 새 password(credential)를 선택된 여러 connection에 일괄 적용합니다.
    - 변경된 connection 목록을 표 형태로 보여줍니다.

기본 접속 동작:
  1) sshctl
     - 전체 connection 목록에서 번호(#)를 선택해 접속합니다.

  2) sshctl <expr>
     - (선택) -n|--number <N> 을 함께 주면, 목록을 보여주지 않고 N번째 항목으로 바로 접속합니다.
       예: sshctl mycom -n 2 / sshctl -n 2 mycom

     - <expr> 이 "-" 로 시작하는 옵션이 아니면 검색식으로 간주합니다.
     - expr 으로 필터링 후, 번호(#)를 선택해 접속합니다.
     - auth_type 이 password 인 경우, sshpass 가 설치되어 있어야 하며,
       설치되어 있지 않으면 이번 접속은 취소하고 sshpass 설치를 시도합니다.

검색식 (Search expression) 예:
  {dev} or {%prod%} and {web}
  - {키워드} : group/name/host 에 키워드가 포함된 항목
  - %문자열% : 문자열을 포함하는 항목
  - 문자열%  : 해당 문자열로 시작하는 항목
  - %문자열  : 해당 문자열로 끝나는 항목
  - and / or : 조건 결합 (중첩 중괄호 형태도 지원)

정렬 규칙 (Sort rule):
  1) group == "default" 인 항목이 항상 최상위
  2) 그 외 group 은 오름차순 정렬
  3) 같은 group 내에서는 name 오름차순 정렬

컬럼 순서 (Column order):
  #, Group, Name, Host, Port, User, Credential(표시 시 마스킹 또는 평문)
EOF
}

# =======================================
# Common utils
# =======================================

##
# 로그를 stderr로 출력한다. 포맷은 [LEVEL] message 형태이다.
# Print log messages to stderr in the form of [LEVEL] message.
#
# @param $1 {string} 로그 레벨 (예: INFO, WARN, ERROR) / log level (e.g. INFO, WARN, ERROR)
# @param $2..$n {string} 출력할 메시지 조각들 / message tokens to be printed
#
# @return {int} 항상 0 (표준에러로만 출력) / always 0 (only writes to stderr)
##
log() {
  local level="$1"
  shift
  printf '[%s] %s\n' "${level}" "$*" >&2
}

##
# 에러 메시지를 help()를 통해 출력하고 스크립트를 종료한다.
# Print an error message via help() and terminate the script.
#
# @param $1..$n {string} 에러 메시지 전체 (공백 포함) / full error message (can include spaces)
#
# @return {int} exit 1로 프로세스를 즉시 종료 / terminates the process with exit code 1
##
die() {
  local msg="$*"
  local line="${BASH_LINENO[0]:-0}"
  help "$msg" "$line"
  exit 1
}

##
# 설정 디렉토리와 설정 파일을 보장하고, 없으면 기본 JSON 구조로 생성한다.
# Ensure the configuration directory/file exist; create with default JSON if missing.
#
# @param $1 없음 / none
#
# @return {int} 성공 시 0, 디렉토리/파일 생성 실패 시 비-0 가능
#         0 on success, non-zero on directory/file creation failure.
##
ensure_config_file() {
  # CONFIG_FILE 기준으로 CONFIG_DIR 재계산
  CONFIG_DIR="$(dirname "${CONFIG_FILE}")"

  if [[ ! -d "${CONFIG_DIR}" ]]; then
    mkdir -p "${CONFIG_DIR}"
  fi

  # masterkey 파일이 존재하면 md5 계산
  local masterkey_md5=""
  if [[ -f "${MASTERKEY_FILE}" ]]; then
    masterkey_md5="$(md5sum "${MASTERKEY_FILE}" | awk '{print $1}')"
  fi

  if [[ ! -f "${CONFIG_FILE}" ]]; then
    # 새 configuration 파일 생성 시 masterkey_md5 포함
    cat > "${CONFIG_FILE}" <<EOF
{
  "version": "${CONFIG_VERSION}",
  "masterkey_md5": "${masterkey_md5}",
  "connections": []
}
EOF
    chmod 600 "${CONFIG_FILE}"
  else
    chmod 600 "${CONFIG_FILE}" || true
  fi
}

##
# jq, ssh 등의 필수 의존성을 점검하고, 누락된 경우 자동 설치 후 안내하고 종료한다.
# Check required dependencies (jq, ssh, md5sum); install missing ones in one shot, notify, and exit.
#
# @param $1 없음 / none
#
# @return {int} 모든 의존성이 존재하면 0
#         If dependencies were installed successfully, prints a message and exits 0 (user should rerun).
#         설치 실패/권한 부족/지원되지 않는 환경이면 die() 로 종료 (비-0)
#         Terminates via die() (non-zero) on failure/privilege issue/unsupported environment.
##
ensure_dependencies() {
  local missing_cmds=()
  local pkgs=()

  # ---------------------------------------
  # helpers (local)
  # ---------------------------------------
  _add_unique() {
    local arr_name="$1"
    local val="$2"
    local x
    eval "for x in \"\${${arr_name}[@]-}\"; do
      if [[ \"\${x}\" == \"\${val}\" ]]; then
        return 0
      fi
    done"
    eval "${arr_name}+=(\"\${val}\")"
  }

  _progress_line() {
    # 한 줄 진행 표시 / One-line progress display.
    # - \r: line rewind, \033[K: clear to end of line
    printf '\r%s\033[K' "$1"
  }

  _progress_done() {
    printf '\r%s\033[K\n' "$1"
  }

  _run_quiet_or_die() {
    # 출력 억제 + 실패 시 로그 출력 / Suppress output; show logs on failure.
    # @param $1 {string} label
    # @param $2... command
    local label="$1"
    shift

    local tmp_out
    tmp_out="$(mktemp -t sshctl-dep.XXXXXX)"
    _progress_line "⏳ ${label} ..."
    if ! "$@" >"${tmp_out}" 2>&1; then
      _progress_done "❌ ${label} 실패"
      echo "---- command output (begin) ----" >&2
      cat "${tmp_out}" >&2
      echo "---- command output (end) ----" >&2
      rm -f "${tmp_out}"
      die "${label} failed."
    fi
    rm -f "${tmp_out}"
    _progress_done "✅ ${label} 완료"
  }

  # ---------------------------------------
  # 1) detect package manager
  # ---------------------------------------
  local is_deb=false
  local is_rpm=false

  if command -v apt-get >/dev/null 2>&1; then
    is_deb=true
  fi
  if command -v dnf >/dev/null 2>&1 || command -v yum >/dev/null 2>&1; then
    is_rpm=true
  fi

  # ---------------------------------------
  # 2) check all required commands first
  # ---------------------------------------
  if ! command -v jq >/dev/null 2>&1; then
    missing_cmds+=( "jq" )
    _add_unique pkgs "jq"
  fi

  if ! command -v ssh >/dev/null 2>&1; then
    missing_cmds+=( "ssh" )
    if ${is_deb}; then
      _add_unique pkgs "openssh-client"
    else
      _add_unique pkgs "openssh-clients"
    fi
  fi

  if ! command -v md5sum >/dev/null 2>&1; then
    missing_cmds+=( "md5sum" )
    # md5sum is usually in coreutils (RHEL/Ubuntu). / 대부분 coreutils
    _add_unique pkgs "coreutils"
  fi

  # nothing missing
  if [[ "${#missing_cmds[@]}" -eq 0 ]]; then
    return 0
  fi

  # ---------------------------------------
  # 3) prepare privilege runner (sudo/root)
  # ---------------------------------------
  local runner_cmd=()
  if [[ "$(id -u)" -ne 0 ]]; then
    if command -v sudo >/dev/null 2>&1; then
      runner_cmd=(sudo)
      echo "============================================================================"
      echo "❗ sshctl 실행에 필요한 의존성 도구가 없습니다. 자동 설치를 진행합니다."
      echo "❗ Missing required tools for sshctl. Installing required packages."
      echo
      echo "⚠️  관리자 권한이 필요합니다. 곧 sudo 비밀번호 입력을 요청할 수 있습니다."
      echo "⚠️  Root privilege is required. sudo may prompt for your password."
      echo "============================================================================"
      echo
    else
      die "Missing dependencies (${missing_cmds[*]}). Need root or sudo to install: ${pkgs[*]}"
    fi
  else
    echo "============================================================================"
    echo "❗ sshctl 실행에 필요한 의존성 도구가 없습니다. 자동 설치를 진행합니다."
    echo "❗ Missing required tools for sshctl. Installing required packages."
    echo "============================================================================"
    echo
  fi

  printf '⚙️  missing commands: %s\n' "${missing_cmds[*]}"
  printf '⚙️  install packages: %s\n' "${pkgs[*]}"
  echo

  # ---------------------------------------
  # 4) install missing packages in one shot
  #    - apt-get update output suppression/standardization applied
  # ---------------------------------------
  if ${is_deb}; then
    # apt-get update: suppress output, standardize options
    # -qq: less output, Use-Pty=0: avoid interactive progress noise
    _run_quiet_or_die "apt-get update" \
      "${runner_cmd[@]}" apt-get -o Dpkg::Use-Pty=0 update -qq

    # apt-get install: suppress output, noninteractive, one shot
    _run_quiet_or_die "apt-get install (${pkgs[*]})" \
      env DEBIAN_FRONTEND=noninteractive \
      "${runner_cmd[@]}" apt-get -o Dpkg::Use-Pty=0 install -y -qq --no-install-recommends "${pkgs[@]}"

  elif command -v dnf >/dev/null 2>&1; then
    _run_quiet_or_die "dnf install (${pkgs[*]})" \
      "${runner_cmd[@]}" dnf -y -q install "${pkgs[@]}"

  elif command -v yum >/dev/null 2>&1; then
    _run_quiet_or_die "yum install (${pkgs[*]})" \
      "${runner_cmd[@]}" yum -y -q install "${pkgs[@]}"

  else
    die "Cannot install dependencies automatically: unsupported package manager. Missing: ${missing_cmds[*]}"
  fi

  # ---------------------------------------
  # 5) re-check after install
  # ---------------------------------------
  local still_missing=()
  if ! command -v jq >/dev/null 2>&1; then
    still_missing+=( "jq" )
  fi
  if ! command -v ssh >/dev/null 2>&1; then
    still_missing+=( "ssh" )
  fi
  if ! command -v md5sum >/dev/null 2>&1; then
    still_missing+=( "md5sum" )
  fi

  if [[ "${#still_missing[@]}" -gt 0 ]]; then
    die "Dependency installation completed but some commands are still missing: ${still_missing[*]}"
  fi

  # ---------------------------------------
  # 6) notify and exit (user should rerun)
  # ---------------------------------------
  echo
  echo "✅ 'sshctl' 프로그램에 필요한 도구를 모두 설치하였습니다. 프로그램을 다시 실행시켜 주세요."
  echo "✅ Installed all required tools for 'sshctl'. Please rerun the program."
  echo
  exit 0
}

##
# configuration.masterkey_md5 와 실제 MASTERKEY_FILE md5 를 비교해 정합성을 검증한다.
# MASTERKEY_FILE 이 없으면 OpenSSH private key 를 생성하고, 필요한 경우 사용자에게
# 새로운 masterkey 경로를 입력받아 configuration 과의 정합성을 맞춘다.
# Verify consistency between configuration.masterkey_md5 and actual MASTERKEY_FILE md5.
# If MASTERKEY_FILE does not exist, create an OpenSSH private key, and if necessary,
# interactively ask the user for a new masterkey path until it matches configuration.
#
# @param $1 없음 / none
#
# @return {int} 성공 시 0, 사용자 취소 또는 복구 불가 시 die() 를 통해 종료
#         0 on success; terminates via die() when user cancels or mismatch cannot be resolved.
##
ensure_masterkey_md5() {
  # 1) MASTERKEY_FILE 이 존재하지 않으면 OpenSSH private key 생성
  # 1) If MASTERKEY_FILE does not exist, create an OpenSSH private key.
  if [[ ! -f "${MASTERKEY_FILE}" ]]; then
    local key_dir
    key_dir="$(dirname "${MASTERKEY_FILE}")"

    if [[ ! -d "${key_dir}" ]]; then
      mkdir -p "${key_dir}"
    fi

    echo
    echo "❗ masterkey(OpenSSH private key) 파일이 존재하지 않습니다."
    echo "❗ 새로운 masterkey 파일을 생성합니다."
    echo "❓ ssh-keygen 실행 중에 표시되는 프롬프트에 따라 비밀번호(passphrase)를 입력해 주세요."
    echo "🔑 target: ${MASTERKEY_FILE}"
    echo

    # 사용자가 직접 passphrase 를 입력하도록 ssh-keygen 을 그대로 실행
    # Run ssh-keygen as-is so the user can provide a passphrase interactively.
    if ! ssh-keygen -t ed25519 -f "${MASTERKEY_FILE}"; then
      die "masterkey(OpenSSH private key) 생성에 실패했습니다. (ssh-keygen 실패)"
    fi

    if [[ ! -f "${MASTERKEY_FILE}" ]]; then
      die "masterkey(OpenSSH private key) 파일이 생성되지 않았습니다: ${MASTERKEY_FILE}"
    fi

    # *.pub 파일 삭제
    shred -u "${MASTERKEY_FILE}.pub"
  fi

  # 2) configuration 파일이 없으면 생성
  # 2) If configuration file does not exist, create it first.
  if [[ ! -f "${CONFIG_FILE}" ]]; then
    ensure_config_file
  fi

  # 3) MASTERKEY_FILE md5 계산
  # 3) Calculate md5 of MASTERKEY_FILE.
  local file_md5
  file_md5="$(md5sum "${MASTERKEY_FILE}" | awk '{print $1}')"

  # 4) configuration 안의 masterkey_md5 읽기 (없으면 빈 문자열)
  # 4) Read masterkey_md5 from configuration (empty if missing).
  local config_md5
  config_md5="$(jq -r '.masterkey_md5 // ""' "${CONFIG_FILE}" 2>/dev/null || echo "")"

  # 5) configuration.masterkey_md5 가 없거나 비어 있으면 현재 md5 로 설정
  # 5) If configuration.masterkey_md5 is missing/empty, set it to current md5.
  if [[ -z "${config_md5}" || "${config_md5}" == "null" ]]; then
    local tmp
    tmp="$(mktemp "${CONFIG_FILE}.XXXXXX")"
    jq --arg md5 "${file_md5}" '.masterkey_md5 = $md5' "${CONFIG_FILE}" > "${tmp}"
    mv "${tmp}" "${CONFIG_FILE}"
    chmod 600 "${CONFIG_FILE}" || true
    return 0
  fi

  # 6) 값이 동일하면 정상 진행
  # 6) If md5 values are equal, everything is consistent.
  if [[ "${config_md5}" == "${file_md5}" ]]; then
    return 0
  fi

  # 7) 값이 다르면 사용자에게 새로운 masterkey 파일 경로를 입력받아 재검증
  # 7) If md5 values differ, ask the user for a new masterkey path and re-validate.
  local current_path="${MASTERKEY_FILE}"
  local current_md5="${file_md5}"

  while true; do
    local line
    line="============================================================================"

    echo "${line}"
    printf '⚙️  masterkey_file              : %s\n' "${current_path}"
    printf '⚙️  masterkey_file.md5          : %s\n' "${current_md5}"
    printf '⚙️  configuration.masterkey_md5 : %s\n' "${config_md5}"
    echo "${line}"
    echo
    echo "❗ MASTERKEY_FILE 과 configuration.masterkey_md5 값이 일치하지 않습니다."
    echo "❗ configuration 에 저장된 masterkey_md5 와 동일한 masterkey 파일 경로를 입력해 주세요."
    echo 
    echo "   (입력을 비우고 Enter 를 누르면 작업을 취소합니다.)"
    echo

    printf "새 masterkey 파일 경로를 입력하세요: "
    local new_path
    IFS= read -er new_path || {
      die "masterkey 검증 중 입력을 읽지 못했습니다."
    }

    # 사용자가 빈 문자열을 입력하면 취소로 간주
    # Treat empty input as user cancellation.
    if [[ -z "${new_path}" ]]; then
      die "masterkey 검증이 사용자에 의해 취소되었습니다."
    fi

    # 경로 존재 여부 검증
    # Verify that the given path exists.
    local abs_new_path=$(resolve_path_abs "${new_path}")
    if [[ ! -f "${abs_new_path}" ]]; then
      echo "❗ 지정한 masterkey 파일을 찾을 수 없습니다: ${abs_new_path}" >&2
      echo 
      echo "   다시 시도해 주세요."
      echo
      continue
    fi

    # 새 파일의 md5 계산
    local new_md5
    new_md5="$(md5sum "${abs_new_path}" | awk '{print $1}')"

    if [[ "${new_md5}" == "${config_md5}" ]]; then
      # 일치하면 MASTERKEY_FILE 을 새 경로로 갱신하고 정상 종료
      # On match, update MASTERKEY_FILE and return success.
      MASTERKEY_FILE="${abs_new_path}"
      return 0
    fi

    # 일치하지 않으면 현재 값 갱신 후 루프 반복
    # If mismatched, update current values and loop.
    current_path="${abs_new_path}"
    current_md5="${new_md5}"
  done
}

##
# 입력된 평문(민감정보: username, credential)을 AES-256-CBC 방식으로 암호화한다.
# Encrypt plaintext (username, credential) using AES-256-CBC with key derived from MASTERKEY_FILE.
#
# @param $1 {string} plaintext 평문 데이터
#
# @return {string} ENC::<base64_cipher>
##
encrypt_value() {
  local plaintext="$1"

  # 빈 문자열은 암호화할 필요 없음
  if [[ -z "$plaintext" ]]; then
    echo ""
    return 0
  fi

  # 파생키 생성: SHA-256(masterkey 파일 내용)
  local derived_key
  derived_key="$(sha256sum "${MASTERKEY_FILE}" | awk '{print $1}')"

  # AES-256-CBC 암호화 (base64 출력)
  local cipher
  # Base64 단일 라인 강제
  cipher="$(echo -n "$plaintext" \
      | openssl enc -aes-256-cbc -a -A -salt -pass pass:"$derived_key" 2>/dev/null)"

  if [[ $? -ne 0 || -z "$cipher" ]]; then
    die "민감정보 암호화(encrypt_value) 중 오류가 발생했습니다."
  fi

  echo "ENC::${cipher}"
}

##
# 입력된 값이 ENC:: 로 시작하면 복호화하여 평문을 반환한다.
# If value starts with ENC::, decrypt it using AES-256-CBC with derived key.
#
# @param $1 {string} value 암호문 또는 평문
#
# @return {string} 평문 데이터
##
decrypt_value_if_needed() {
  local value="$1"

  # 암호문이 아니라면 그대로 반환
  if [[ "$value" != ENC::* ]]; then
    echo "$value"
    return 0
  fi

  # cipher 부분만 추출
  local cipher="${value#ENC::}"

  # 파생키 생성
  local derived_key
  derived_key="$(sha256sum "${MASTERKEY_FILE}" | awk '{print $1}')"

  # 복호화
  local plaintext
  plaintext="$(echo "$cipher" \
      | openssl enc -aes-256-cbc -a -d -salt -pass pass:"$derived_key" 2>/dev/null)"

  if [[ $? -ne 0 ]]; then
    die "민감정보 복호화(decrypt_value_if_needed) 중 오류가 발생했습니다."
  fi

  echo "$plaintext"
}

##
# STDIN으로 전달된 JSON을 임시 파일을 사용해 CONFIG_FILE에 안전하게 저장한다.
# Safely save JSON from STDIN into CONFIG_FILE using a temporary file.
#
# @param $1 없음 (입력은 STDIN으로 전달) / none (input JSON is read from STDIN)
#
# @return {int} 성공 시 0, 파일 쓰기/이동 실패 시 비-0
#         0 on success; non-zero on write/move failures.
##
save_connections_json() {
  local tmp
  tmp="$(mktemp "${CONFIG_FILE}.XXXXXX")"
  cat > "${tmp}"
  mv "${tmp}" "${CONFIG_FILE}"
  chmod 600 "${CONFIG_FILE}"
}

##
# ~, 상대경로 등을 포함한 경로를 절대경로로 정규화한다.
# Normalize a given path (including ~ and relative paths) into an absolute path.
#
# @param $1 {string} 원본 경로 (상대/절대/tilde 포함 가능) / original path (relative/absolute/tilde)
#
# @return {string} STDOUT로 절대경로를 출력 / prints the absolute path to STDOUT
# @return {int} 항상 0 (readlink 오류 시 원래 경로 기준) / always 0; falls back when readlink fails.
##
resolve_path_abs() {
  local p="$1"

  if [[ -z "$p" ]]; then
    printf '%s\n' ""
    return 0
  fi

  if [[ "$p" == ~* ]]; then
    p="${p/#\~/$HOME}"
  fi

  if [[ "$p" != /* ]]; then
    p="${PWD}/${p}"
  fi

  if command -v readlink >/dev/null 2>&1; then
    local r
    if r=$(readlink -f -- "$p" 2>/dev/null); then
      p="$r"
    fi
  fi

  printf '%s\n' "$p"
}

##
# 입력받은 key path의 환경변수 문법 오류 및 허용되지 않는 문자를 검증합니다.
#
# @param $1 {string} 검증할 경로 문자열
# @return 유효하면 0, 문법 오류 또는 금지 문자 발견 시 1 반환
##
validate_key_path_syntax() {
  local p="$1"
  [[ -z "$p" ]] && return 0

  # 1) ${xxx 문법 오류 검사 (닫히지 않은 중괄호)
  local remainder="$p"
  while [[ "$remainder" == *"\${"* ]]; do
    remainder="${remainder#*\$\{}"
    if [[ "$remainder" != *"}"* ]]; then
      printf '입력 오류: 환경변수 문법 오류가 발생했습니다. (닫히지 않은 "${")\n' >&2
      return 1
    fi
  done

  # 2) 제어 문자 등 경로명에 사용할 수 없는 유해 문자 검증
  if [[ "$p" =~ [[:cntrl:]] ]]; then
    printf '입력 오류: 경로명에 허용되지 않는 문자(제어 문자)가 포함되어 있습니다.\n' >&2
    return 1
  fi

  return 0
}

##
# 입력받은 key path의 맨 앞 틸드(~)를 $HOME 문자열로 변환하여 저장용 경로로 정규화합니다.
# (중간에 있는 틸드는 무시하며, ~username 패턴 보호를 위해 ~/ 또는 ~ 인 경우만 변환)
#
# @param $1 {string} 원본 경로
# @return STDOUT로 정규화된 경로 출력
##
normalize_key_path_for_save() {
  local p="$1"
  if [[ "$p" == "~" ]]; then
    printf '%s\n' "\$HOME"
  # [수정] 틸드가 쉘에 의해 강제 확장되지 않도록 "~/"로 따옴표 처리
  elif [[ "$p" == "~/"* ]]; then
    printf '%s\n' "\$HOME${p:1}"
  else
    printf '%s\n' "$p"
  fi
}

##
# 저장된 원본 경로를 런타임 시점에 이스케이프 규칙에 맞춰 동적으로 확장합니다.
#
# @param $1 {string} 저장된 원본 경로
# @return STDOUT로 동적 치환이 완료된 최종 절대경로 출력
##
expand_key_path_runtime() {
  local p="$1"
  [[ -z "$p" ]] && { echo ""; return 0; }

  # 1) $(...) 명령어 치환 무력화를 위한 마스킹 격리
  while [[ "$p" == *"\$("* ]]; do
    p="${p//\$(/__LITERAL_CMD_START__}"
  done

  # 2) \$xxx 문자열 보존을 위한 마스킹 격리
  while [[ "$p" == *"\\$"* ]]; do
    p="${p//\\$/__ESCAPED_DOLLAR_SIGN__}"
  done

  # [핵심 수정 1] 정규식을 별도의 변수에 할당하여 Bash 버전(3.2~5.x) 간의
  # 정규식 엔진 파싱(역슬래시 해석) 오류 및 매칭 실패 문제를 완벽히 해결합니다.
  local re_bare='\$([A-Za-z_][A-Za-z0-9_]*)'
  local re_braced='\$\{([A-Za-z_][A-Za-z0-9_]*)\}'

  local max_iter=20
  local iter=0

  # 3) $VAR 형식 확장
  iter=0
  while [[ "$p" =~ $re_bare ]] && (( iter < max_iter )); do
    local var_name="${BASH_REMATCH[1]}"
    local var_val="${!var_name:-}"
    # [핵심 수정 2] 타겟 문자열을 작은따옴표로 결합하여 치환자 인식 오류 차단
    local target='$'${var_name}
    p="${p//"$target"/${var_val}}"
    ((iter++))
  done

  # 4) ${VAR} 형식 확장
  iter=0
  while [[ "$p" =~ $re_braced ]] && (( iter < max_iter )); do
    local var_name="${BASH_REMATCH[1]}"
    local var_val="${!var_name:-}"
    # [핵심 수정 2] 타겟 문자열을 작은따옴표로 결합하여 치환자 인식 오류 차단
    local target='${'${var_name}'}'
    p="${p//"$target"/${var_val}}"
    ((iter++))
  done

  # 5) 마스킹했던 특수 토큰 복원 (이스케이프 역슬래시 소진)
  while [[ "$p" == *"__ESCAPED_DOLLAR_SIGN__"* ]]; do
    # 사용자가 이스케이프 목적으로 입력한 '\'를 소진시키고 순수 '$'만 남깁니다.
    p="${p//__ESCAPED_DOLLAR_SIGN__/$}"
  done

  while [[ "$p" == *"__LITERAL_CMD_START__"* ]]; do
    p="${p//__LITERAL_CMD_START__/\$(}"
  done

  # 6) 틸드(~) 기호 사용자 홈 디렉토리 확장
  if [[ "$p" == ~* ]]; then
    p="${p/#\~/$HOME}"
  fi

  echo "$p"
}

##
# SHOW_CREDENTIAL 플래그에 따라 credential 출력값을 결정한다.
# Decide how to display credential value depending on SHOW_CREDENTIAL flag.
#
# @param $1 {string} cred 실제 credential 값 / actual credential value
#
# @return {string} STDOUT로 표시용 credential 출력 / prints displayable credential to STDOUT.
# @return {int} 항상 0 / always 0.
##
format_credential_for_display() {
  local cred="$1"

  case "$EXEC_CMD" in
    # [연결정보 목록] (-l | --list-all)
    # [연결정보 수정] (-m | --modify-connection)
    # - 기본: masking list (****************)
    # - -s / --show-credential 이 있는 경우: plain list
    list | modify)
      if [[ "$SHOW_CREDENTIAL" == "true" ]]; then
        printf '%s' "$cred"
      else
        printf '****************'
      fi
      ;;

    # [연결정보 추가] (-a | --add-connection)
    # - 기본: masking list
    # - -s / --show-credential 이 있는 경우: 미리보기에서만 plain
    add)
      if [[ "$SHOW_CREDENTIAL" == "true" ]]; then
        printf '%s' "$cred"
      else
        printf '****************'
      fi
      ;;

    # [비밀번호 일괄변경] (-mc | --modify-credential)
    # - 기본: "plain list"
    modify-credential)
      printf '%s' "$cred"
      ;;

    # [서버 접속], [연결정보 삭제], [연결정보 그룹이동]
    # - 요구사항: 항상 "masking list"
    # - --show-credential 옵션 지원하지 않음 → 항상 마스킹
    connect|delete|move-group)
      printf '****************'
      ;;

    # 그 외 (안전하게 기본은 마스킹)
    *)
      printf '****************'
      ;;
  esac
}

##
# sshpass 가 없을 경우 시스템 패키지 관리자(apt, yum/dnf, zypper, apk 등)를 사용해 설치를 시도한다.
# Try to install sshpass using system package manager (apt, yum/dnf, zypper, apk, etc.) if not present.
#
# @param $1 없음 / none
#
# @return {int} 설치 후 sshpass 가 사용 가능하면 0, 그렇지 않으면 1
#         0 if sshpass becomes available after installation; 1 otherwise.
##
install_sshpass_if_missing() {
  if command -v sshpass >/dev/null 2>&1; then
    return 0
  fi

  log INFO "sshpass not found. Trying to install..."

  local pm=""
  if command -v apt-get >/dev/null 2>&1; then
    pm="apt"
  elif command -v dnf >/dev/null 2>&1; then
    pm="dnf"
  elif command -v yum >/dev/null 2>&1; then
    pm="yum"
  elif command -v zypper >/dev/null 2>&1; then
    pm="zypper"
  elif command -v apk >/dev/null 2>&1; then
    pm="apk"
  fi

  case "$pm" in
    apt)
      if sudo apt-get update && sudo apt-get install -y sshpass; then
        log INFO "sshpass installed via apt."
      fi
      ;;
    dnf)
      if sudo dnf install -y sshpass; then
        log INFO "sshpass installed via dnf."
      fi
      ;;
    yum)
      if sudo yum install -y sshpass; then
        log INFO "sshpass installed via yum."
      fi
      ;;
    zypper)
      if sudo zypper install -y sshpass; then
        log INFO "sshpass installed via zypper."
      fi
      ;;
    apk)
      if sudo apk add sshpass; then
        log INFO "sshpass installed via apk."
      fi
      ;;
    *)
      log WARN "Unsupported package manager. Please install sshpass manually."
      ;;
  esac

  if command -v sshpass >/dev/null 2>&1; then
    return 0
  fi
  return 1
}

# =======================================
# Validation helpers
# =======================================

##
# 값이 비어 있지 않은지 검사한다. 비어 있으면 에러 메시지를 출력한다.
# Validate that a given value is not empty; prints an error message if it is empty.
#
# @param $1 {string} 필드 레이블 (예: group, name) / field label (e.g. group, name)
# @param $2 {string} 실제 값 / actual value
#
# @return {int} 비어 있지 않으면 0, 비어 있으면 1
#         0 if non-empty; 1 if empty.
##
validate_non_empty() {
  local label="$1"
  local value="$2"
  if [[ -z "$value" ]]; then
    printf '입력 오류: %s 은(는) 비어 있을 수 없습니다.\n' "$label" >&2
    return 1
  fi
  return 0
}

##
# host_type 값이 ipv4|ipv6|domain 중 하나인지 확인한다.
# Validate that host_type is one of ipv4, ipv6, or domain.
#
# @param $1 {string} host_type 값 / host_type value
#
# @return {int} 유효하면 0, 잘못된 값이면 1
#         0 if valid; 1 if invalid.
##
validate_host_type() {
  local value="$1"
  case "$value" in
    ipv4|ipv6|domain)
      return 0
      ;;
    *)
      printf '입력 오류: host_type 은 ipv4|ipv6|domain 중 하나여야 합니다. (현재: %s)\n' "$value" >&2
      return 1
      ;;
  esac
}

##
# auth_type 값이 password|key 중 하나인지 확인한다.
# Validate that auth_type is either password or key.
#
# @param $1 {string} auth_type 값 / auth_type value
#
# @return {int} 유효하면 0, 잘못된 값이면 1
#         0 if valid; 1 if invalid.
##
validate_auth_type() {
  local value="$1"
  case "$value" in
    password|key)
      return 0
      ;;
    *)
      printf '입력 오류: auth_type 은 password|key 중 하나여야 합니다. (현재: %s)\n' "$value" >&2
      return 1
      ;;
  esac
}

##
# port 값이 숫자이고 1~65535 범위인지 확인한다.
# Validate that port is numeric and in the range 1–65535.
#
# @param $1 {string} 포트 문자열 / port string
#
# @return {int} 유효하면 0, 잘못된 값이면 1
#         0 if valid; 1 if invalid.
##
validate_port() {
  local value="$1"
  if ! [[ "$value" =~ ^[0-9]+$ ]]; then
    printf '입력 오류: port 는 숫자여야 합니다. (현재: %s)\n' "$value" >&2
    return 1
  fi
  if (( value < 1 || value > 65535 )); then
    printf '입력 오류: port 범위는 1 ~ 65535 입니다. (현재: %s)\n' "$value" >&2
    return 1
  fi
  return 0
}

##
# host_type 유형에 따라 host 형식을 검증한다.
# Validate host format based on host_type (ipv4, ipv6, or domain).
#
# @param $1 {string} host_type (ipv4|ipv6|domain)
# @param $2 {string} host 값 / host value
#
# @return {int} 유효하면 0, 잘못된 경우 1
#         0 if valid; 1 if invalid.
##
validate_host_by_type() {
  local host_type="$1"
  local host="$2"

  case "$host_type" in
    ipv4)
      if ! [[ "$host" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
        printf '입력 오류: ipv4 host 형식이 올바르지 않습니다. (예: 192.168.0.10)\n' >&2
        return 1
      fi
      ;;
    ipv6)
      if [[ "$host" != *:* ]]; then
        printf '입력 오류: ipv6 host 는 ":" 를 포함해야 합니다.\n' >&2
        return 1
      fi
      ;;
    domain)
      if ! [[ "$host" =~ ^[A-Za-z0-9.-]+$ ]]; then
        printf '입력 오류: domain host 형식이 올바르지 않습니다. (예: gitlab.ymtech.co.kr)\n' >&2
        return 1
      fi
      ;;
    *)
      printf '입력 오류: 알 수 없는 host_type 입니다: %s\n' "$host_type" >&2
      return 1
      ;;
  esac
  return 0
}

# =======================================
# Prompt label width 초기화
# =======================================

##
# 프롬프트에서 사용할 필드명 길이를 기준으로 PROMPT_LABEL_WIDTH를 계산한다.
# Compute PROMPT_LABEL_WIDTH based on the maximum length of field labels.
#
# @param $1 없음 / none
#
# @return {int} 항상 0, PROMPT_LABEL_WIDTH 전역 변수 설정
#         Always 0; sets global PROMPT_LABEL_WIDTH.
##
init_prompt_label_width() {
  local labels=(
    "group"
    "name"
    "host_type (ipv4|ipv6|domain)"
    "host"
    "port"
    "username"
    "auth_type (password|key)"
    "password"
    "key path"
    "새 group"
  )
  local max=0 len
  for f in "${labels[@]}"; do
    len=${#f}
    if (( len > max )); then
      max=$len
    fi
  done
  # 아이콘(2칸 가정) + 공백 2칸 + 필드명 + 여유 2칸
  PROMPT_LABEL_WIDTH=$((max + 6))
}

# =======================================
# Search expression → jq filter
# =======================================

##
# 단일 키워드(와일드카드 % 포함)를 이용해 group/name/host에 대한 jq 조건식을 생성한다.
# Build a jq condition for a single keyword (with % wildcards) over group/name/host.
#
# @param $1 {string} 검색 키워드 (예: git, g%, %lab, %prod%) / search keyword with optional % wildcards
#
# @return {string} STDOUT로 jq boolean 표현식 출력 / prints jq boolean expression to STDOUT
# @return {int} 0 (정상) / 0 on success.
##
build_single_condition() {
  local kw="$1"
  local mode="contains"
  local core="$kw"

  if [[ "$core" == %*% ]]; then
    core="${core#%}"
    core="${core%%%}"
    mode="contains"
  elif [[ "$core" == *% ]]; then
    core="${core%%%}"
    mode="starts"
  elif [[ "$core" == %* ]]; then
    core="${core#%}"
    mode="ends"
  else
    mode="contains"
  fi

  local core_l="${core,,}"

  local esc
  esc="$(printf '%s' "$core_l" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"

  local field_expr_group='.group // "" | ascii_downcase'
  local field_expr_name='.name // "" | ascii_downcase'
  local field_expr_host='.host // "" | ascii_downcase'

  local cmp_func=""
  case "$mode" in
    contains)
      cmp_func="contains(\"$esc\")"
      ;;
    starts)
      cmp_func="startswith(\"$esc\")"
      ;;
    ends)
      cmp_func="endswith(\"$esc\")"
      ;;
    *)
      cmp_func="contains(\"$esc\")"
      ;;
  esac

  printf '((%s | %s) or (%s | %s) or (%s | %s))' \
    "$field_expr_group" "$cmp_func" \
    "$field_expr_name"  "$cmp_func" \
    "$field_expr_host"  "$cmp_func"
}

##
# 전체 검색식(expr)을 파싱하여 AND/OR 조합 jq filter 표현식으로 변환한다.
# Parse a whole search expression and convert it into a jq filter with AND/OR conditions.
#
# @param $1 {string} 검색식 문자열 (예: {dev} or {%prod%} and {web}) / raw search expression string
#
# @return {string} STDOUT로 완성된 jq filter 문자열 출력 / prints final jq filter string to STDOUT
# @return {int} 0 (정상), 검색식이 비어 있으면 "true" 출력
#         0 on success; prints "true" for empty expressions.
##
build_search_filter() {
  local expr="$1"

  # 양쪽 공백 제거
  expr="${expr#"${expr%%[![:space:]]*}"}"
  expr="${expr%"${expr##*[![:space:]]}"}"

  # 빈 expr 이면 전체(true)
  if [[ -z "$expr" ]]; then
    echo "true"
    return 0
  fi

  _build_search_filter_inner "$expr"
}

# 내부 재귀 파서
_build_search_filter_inner() {
  local expr="$1"

  # 소문자 + 공백 정규화
  expr="${expr,,}"
  expr="$(printf '%s' "$expr" | tr -s '[:space:]' ' ')"
  expr="${expr#"${expr%%[![:space:]]*}"}"
  expr="${expr%"${expr##*[![:space:]]}"}"

  local conds=()
  local ops=()
  local rest="$expr"

  while [[ -n "$rest" ]]; do
    # 앞쪽 공백 제거
    rest="${rest#"${rest%%[![:space:]]*}"}"
    [[ -z "$rest" ]] && break

    if [[ "${rest:0:1}" == "{" ]]; then
      # 중첩 { } 처리용 brace depth
      local depth=0
      local len=${#rest}
      local i
      for ((i=0; i<len; i++)); do
        local ch="${rest:i:1}"
        if [[ "$ch" == "{" ]]; then
          depth=$((depth+1))
        elif [[ "$ch" == "}" ]]; then
          depth=$((depth-1))
          if (( depth == 0 )); then
            break
          fi
        fi
      done

      # 중괄호 불일치 → 전체를 단일 키워드로 처리
      if (( depth != 0 )); then
        conds=( "$(build_single_condition "$expr")" )
        break
      fi

      local close_pos="$i"
      local inner_len=$((close_pos - 1))
      local inside="${rest:1:inner_len}"   # 가장 바깥 { } 안쪽
      local next_pos=$((close_pos + 1))
      local remaining="${rest:next_pos}"

      if [[ "$inside" == *"{"* ]]; then
        # 내부에 또 { 가 있으면, 다시 Expr 로 재귀 파싱
        local sub_filter
        sub_filter="$(_build_search_filter_inner "$inside")" || return 1
        conds+=( "(${sub_filter})" )
      else
        # 단순 키워드
        conds+=( "$(build_single_condition "$inside")" )
      fi

      rest="$remaining"
    else
      # 안전장치: { 로 시작하지 않는 토큰은 "단일 키워드" 취급
      local token="${rest%% *}"
      local remaining="${rest#* }"
      if [[ "$token" == "$rest" ]]; then
        remaining=""
      fi
      conds+=( "$(build_single_condition "$token")" )
      rest="$remaining"
    fi

    # op (and|or) 파싱
    rest="${rest#"${rest%%[![:space:]]*}"}"
    if [[ "$rest" =~ ^(and|or)[[:space:]]+(.*)$ ]];
    then
      ops+=( "${BASH_REMATCH[1]}" )
      rest="${BASH_REMATCH[2]}"
    elif [[ -n "$rest" ]]; then
      # 검색 엔진처럼 암묵적(implicit) 'and' 연산자로 처리하여 모두 포함
      ops+=( "and" )
    else
      break
    fi
  done

  # term 이 하나도 안 잡혔으면 전체 expr 을 단일 키워드로 처리
  if (( ${#conds[@]} == 0 )); then
    printf '%s\n' "$(build_single_condition "$expr")"
    return 0
  fi

  # 왼쪽부터 fold: ((t1 op1 t2) op2 t3) ...
  local result="${conds[0]}"
  local i
  for ((i=0; i<${#ops[@]}; i++)); do
    local op="${ops[$i]}"
    local rhs="${conds[$((i+1))]}"
    result="(${result} ${op} ${rhs})"
  done

  printf '%s\n' "$result"
}

