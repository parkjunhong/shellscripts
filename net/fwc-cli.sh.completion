# =======================================
# @author   : parkjunhong77@gmail.com
# @title    : firewall-cmd zone info wrapper.
# @license  : Apache License 2.0
# @since    : 2026-06-01
# @desc     : support RHEL, Oracle Linux, Ubuntu, RockyOS
# @installation : 
#   1. insert 'source <path>/fwc-cli.sh" into ~/bin/.bashrc or ~/bin/.bash_profile for a personal usage.
#   2. copy the above file to /etc/bash_completion.d/ or insert 'source <path>/fwc-cli.sh' into 
#      etc/bashrc for all users.
# =======================================
# Global Reserved Variables
# 1. COMP_WORDS: an array, contains all arguments
# 2. COMP_CWORD: a index of a cursor
# 3. COMP_LINE: all command string
# 4. COMPREPLY: an array, contains suggested words. words are sorted and unique.
#
# Arguments of a function
# 1. $1: command
# 2. $2: current
# 3. $3: previous
#
# e.g.: mycmd arg1 arg2 arg3 arg4[tab]
# - $1: mycmd
# - $2: arg4
# - $3: arg3

_fwc_cli_completion() {
  local cur prev opts
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  # 사용 가능한 옵션 목록: =없는 단독 형태와 =있는 형태를 모두 제공
  opts="--zone= --active-zone --reload --permanent \
        --add-sources= --add-services= --add-ports= --add-protocols= \
        --remove-sources --remove-sources= \
        --remove-services --remove-services= \
        --remove-ports --remove-ports= \
        --remove-protocols --remove-protocols= \
        --remove-forward-ports --remove-forward-ports= \
        --remove-source-ports --remove-source-ports= \
        --remove-icmp-blocks --remove-icmp-blocks= \
        --remove-rich-rules --remove-rich-rules= \
        --remove-interfaces --remove-interfaces= \
        -h --help"

  # --zone= 옵션의 동적 자동 완성
  if [[ "${cur}" == --zone=* ]]; then
    local prefix="--zone="
    local typed_zone="${cur#--zone=}"
    local zones=$(sudo firewall-cmd --get-zones 2>/dev/null)
    
    COMPREPLY=( $(compgen -P "$prefix" -W "$zones" -- "$typed_zone") )
    compopt -o nospace 2>/dev/null
    return 0
  fi

  local word
  for word in "${COMP_WORDS[@]}"; do
    if [[ "$word" == "--active-zone" || "$word" == "--reload" || "$word" == "--permanent" || "$word" == "-h" || "$word" == "--help" ]]; then
      opts=$(echo "$opts" | sed "s/\b$word\b//g")
    fi
  done

  COMPREPLY=( $(compgen -W "${opts}" -- "${cur}") )
  return 0
}

complete -F _fwc_cli_completion fwc-cli.sh

