# @since : 2026-03-11
# @desc : support RHEL, Oracle Linux, Ubuntu, RockyOS
# @installation :
# 1. insert 'source <path>/<파일명>" into ~/bin/.bashrc or ~/bin/.bash_profile for a personal usage.
# 2. copy the above file to /etc/bash_completion.d/ or insert 'source <path>/<파일명>' into etc/bashrc for all users.
# =======================================

# 1. OS의 Java 버전 선택 인터페이스 호출 (사용자 인터랙트 대기)
sudo update-alternatives --config java

# 2. update-alternatives로 선택된 java의 실제 물리적 경로 추적
SELECTED_JAVA=$(dirname $(dirname $(readlink -f $(which java))))
ENV_FILE="$HOME/.java_env"

# 3. 부모 쉘이 읽어들일 수 있도록 환경 변수 파일 생성
cat <<EOF > "$ENV_FILE"
# Auto-generated by update-java-config
export JAVA_HOME="$SELECTED_JAVA"
EOF

echo "[System] Java 설정이 갱신되었습니다: $SELECTED_JAVA" >&2

exit 0


